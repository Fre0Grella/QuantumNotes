<script is:inline>
function setFb(id, ok, msg) {
  const el = document.getElementById(id);
  el.className = 'feedback show ' + (ok ? 'ok' : 'no');
  el.textContent = msg;
}

function chk(inputId, correct, exId) {
  const el = document.getElementById(inputId);
  const fb = document.getElementById('f'+inputId.slice(1));
  const val = el.value.trim().toUpperCase().replace(/\s/g,'').replace('⟩','').replace('|','').replace(/°/,'');
  const cmp = correct.toUpperCase().replace(/\s/g,'').replace('⟩','').replace('|','').replace(/°/,'');
  if(val === cmp) {
    el.className = 'answer-input ok';
    fb.className = 'feedback ok show';
    fb.textContent = '✓ Correct!';
  } else if(val.length > 0) {
    el.className = 'answer-input no';
    fb.className = 'feedback no show';
    fb.textContent = '✗ Not quite — try again or show hint.';
  }
}

function chk2(id1, id2, c1, c2, exId) {
  const v1 = document.getElementById(id1).value.trim().replace(/[^0-9.]/g,'');
  const v2 = document.getElementById(id2).value.trim().replace(/[^0-9.]/g,'');
  const fb = document.getElementById('f'+id1.slice(1));
  const ok1 = Math.abs(parseFloat(v1)-parseFloat(c1)) < 2;
  const ok2 = Math.abs(parseFloat(v2)-parseFloat(c2)) < 10;
  if(ok1 && ok2) {
    fb.className = 'feedback ok show';
    fb.textContent = '✓ Correct! θ ≈ 73.7°, φ ≈ 420° (or equivalently 60°).';
    document.getElementById(id1).className='answer-input ok';
    document.getElementById(id2).className='answer-input ok';
  } else if(v1.length > 0 || v2.length > 0) {
    fb.className = 'feedback no show';
    fb.textContent = '✗ Not quite — check the hint.';
  }
}

function chkContains(inputId, keywords, exId) {
  const el = document.getElementById(inputId);
  const fb = document.getElementById('f'+inputId.slice(1));
  const val = el.value.toLowerCase();
  const ok = keywords.some(k => val.includes(k));
  if(ok) {
    el.className = 'answer-input ok';
    fb.className = 'feedback ok show';
    fb.textContent = '✓ Correct!';
  } else if(val.length > 1) {
    el.className = 'answer-input no';
    fb.className = 'feedback no show';
    fb.textContent = '✗ Not quite — try again or show hint.';
  }
}

function chkClose(inputId, target, tol, exId) {
  const el = document.getElementById(inputId);
  const fb = document.getElementById('f'+inputId.slice(1));
  const val = parseFloat(el.value);
  if(isNaN(val)) return;
  if(Math.abs(val - target) <= tol) {
    el.className = 'answer-input ok';
    fb.className = 'feedback ok show';
    fb.textContent = `✓ Correct! (expected ≈ ${target.toFixed(2)})`;
  } else {
    el.className = 'answer-input no';
    fb.className = 'feedback no show';
    fb.textContent = `✗ Not quite — got ${val.toFixed(3)}, expected ≈ ${target.toFixed(2)}. Show hint?`;
  }
}

function showHint(hintId) {
  const el = document.getElementById(hintId);
  el.classList.toggle('show');
}

function goTo(id) {
  const el = document.getElementById(id);
  if(el) el.scrollIntoView({behavior:'smooth', block:'start'});
}

// ── GATE CANVAS ────────────────────────────────────────────────
(function(){
  const cv = document.getElementById('cGates');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  const gates = [
    { name:'H', col:'#2c5282', mat:[[1/Math.SQRT2,1/Math.SQRT2],[1/Math.SQRT2,-1/Math.SQRT2]], desc:'Hadamard: creates superposition' },
    { name:'S', col:'#b7530a', mat:[[1,0],[0,{r:0,i:1}]], desc:'Phase: adds π/2 phase to |1⟩' },
    { name:'T', col:'#1a6b3a', mat:[[1,0],[0,'e^{jπ/4}']], desc:'T gate: adds π/4 phase to |1⟩' },
    { name:'X', col:'#c0392b', mat:[[0,1],[1,0]], desc:'Pauli-X: bit flip |0⟩↔|1⟩' },
    { name:'Z', col:'#6b21a8', mat:[[1,0],[0,-1]], desc:'Pauli-Z: phase flip |1⟩→−|1⟩' },
  ];

  let hovered = -1;

  function draw() {
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

    const gw = 70, gh = 50, gap = 20, startX = 30, y = 30;
    gates.forEach((g,i) => {
      const x = startX + i*(gw+gap);
      const isH = (i===hovered);
      ctx.fillStyle = isH ? g.col : 'white';
      ctx.strokeStyle = g.col;
      ctx.lineWidth = 2;
      ctx.beginPath(); ctx.roundRect(x, y, gw, gh, 4); ctx.fill(); ctx.stroke();

      ctx.fillStyle = isH ? 'white' : g.col;
      ctx.font = 'bold 22px IBM Plex Mono';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(g.name, x+gw/2, y+gh/2);
    });

    if(hovered >= 0) {
      const g = gates[hovered];
      const x = startX + hovered*(gw+gap);
      ctx.fillStyle = '#1a1a14'; ctx.font = '12px IBM Plex Sans';
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(g.desc, x+gw/2, y+gh+10);
    } else {
      ctx.fillStyle = '#888877'; ctx.font = '11px IBM Plex Mono';
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText('hover a gate to see details', W/2, 90);
    }

    // Wires
    ctx.strokeStyle = '#ccc8ba'; ctx.lineWidth = 2;
    const wireY = 55;
    ctx.beginPath(); ctx.moveTo(0, wireY); ctx.lineTo(30, wireY); ctx.stroke();
    gates.forEach((g,i) => {
      const x = startX + i*(gw+gap);
      if(i > 0) { ctx.beginPath(); ctx.moveTo(x-gap, wireY); ctx.lineTo(x, wireY); ctx.stroke(); }
    });
    const lastX = startX + (gates.length-1)*(gw+gap)+gw;
    ctx.beginPath(); ctx.moveTo(lastX, wireY); ctx.lineTo(W, wireY); ctx.stroke();

    // labels
    ctx.fillStyle='#888'; ctx.font='11px IBM Plex Mono';
    ctx.textAlign='left'; ctx.textBaseline='middle';
    ctx.fillText('|ψ⟩', 2, wireY-8);
    ctx.textAlign='right';
    ctx.fillText('|ψ\'⟩', W-2, wireY-8);
  }

  cv.addEventListener('mousemove', e => {
    const r = cv.getBoundingClientRect();
    const mx = (e.clientX-r.left)*(cv.width/r.width);
    const my = (e.clientY-r.top)*(cv.height/r.height);
    const gw=70, gap=20, startX=30, y=30, gh=50;
    let h = -1;
    gates.forEach((g,i) => {
      const x = startX+i*(gw+gap);
      if(mx>=x && mx<=x+gw && my>=y && my<=y+gh) h=i;
    });
    if(h!==hovered){ hovered=h; draw(); }
  });
  cv.addEventListener('mouseleave', () => { hovered=-1; draw(); });
  draw();
})();

// ── PARALLELISM CANVAS ─────────────────────────────────────────
function updateParallel() {
  const n = parseInt(document.getElementById('slN').value);
  document.getElementById('nVal').textContent = n;
  const states = Math.pow(2,n);
  document.getElementById('nStates').textContent = states;

  const cv = document.getElementById('cParallel');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;
  ctx.clearRect(0,0,W,H);

  const cols = Math.min(states, 64);
  const bw = Math.max(4, Math.floor((W-40)/cols)-2);
  const amp = 1/Math.sqrt(states);
  const maxH = 140;

  ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

  for(let i=0; i<cols; i++) {
    const x = 20 + i*(bw+2);
    const barH = amp*amp*maxH*states; // all equal = 1 bar height
    const h = Math.max(4, barH);
    ctx.fillStyle = `hsl(${220+i*2},60%,55%)`;
    ctx.fillRect(x, H-30-h, bw, h);
  }

  if(states > 64) {
    ctx.fillStyle='#888'; ctx.font='12px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText(`(showing first 64 of ${states} states)`, W/2, H-5);
  }

  ctx.fillStyle='#1a1a14'; ctx.font='12px IBM Plex Mono'; ctx.textAlign='center';
  ctx.fillText(`H^⊗${n} |0⟩^⊗${n} = superposition of ${states} states (amplitude = 1/√${states} ≈ ${amp.toFixed(3)} each)`, W/2, 16);

  ctx.fillStyle='#888'; ctx.font='10px IBM Plex Mono'; ctx.textAlign='left';
  ctx.fillText('|0⟩', 20, H-12);
  ctx.textAlign='right';
  if(states<=64) ctx.fillText(`|${states-1}⟩`, 20+(cols-1)*(bw+2)+bw, H-12);
}
updateParallel();

// ── BLOCH SPHERE CANVAS ────────────────────────────────────────
function updateBloch() {
  const theta = parseFloat(document.getElementById('slTheta').value)*Math.PI/180;
  const phi   = parseFloat(document.getElementById('slPhi').value)*Math.PI/180;
  document.getElementById('thetaVal').textContent = document.getElementById('slTheta').value+'°';
  document.getElementById('phiVal').textContent   = document.getElementById('slPhi').value+'°';

  const cv = document.getElementById('cBloch');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

  const cx=W/2, cy=H/2, R=85;
  // Circle
  ctx.strokeStyle='#dedad0'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.arc(cx,cy,R,0,2*Math.PI); ctx.stroke();
  // Equator (ellipse, perspective)
  ctx.strokeStyle='#e8e4d8'; ctx.lineWidth=1; ctx.setLineDash([4,3]);
  ctx.beginPath(); ctx.ellipse(cx,cy,R,R*0.35,0,0,2*Math.PI); ctx.stroke();
  ctx.setLineDash([]);

  // Axes
  ctx.strokeStyle='#ccc8ba'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(cx,cy-R-15); ctx.lineTo(cx,cy+R+10); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx-R-15,cy); ctx.lineTo(cx+R+10,cy); ctx.stroke();

  // Labels
  ctx.fillStyle='#1a1a14'; ctx.font='bold 13px IBM Plex Mono'; ctx.textAlign='center';
  ctx.fillText('|0⟩', cx, cy-R-18);
  ctx.fillText('|1⟩', cx, cy+R+22);
  ctx.textAlign='left';
  ctx.fillText('|+⟩', cx+R+12, cy+4);
  ctx.textAlign='right';
  ctx.fillText('|−⟩', cx-R-8, cy+4);

  // State vector (Bloch projection)
  const bx = cx + R*Math.sin(theta)*Math.cos(phi);
  const by = cy - R*Math.cos(theta);

  ctx.strokeStyle='#c0392b'; ctx.lineWidth=2.5;
  ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(bx,by); ctx.stroke();
  ctx.fillStyle='#c0392b';
  ctx.beginPath(); ctx.arc(bx,by,6,0,2*Math.PI); ctx.fill();

  // Dashed projection
  ctx.strokeStyle='#bbb'; ctx.lineWidth=1; ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.moveTo(bx,by); ctx.lineTo(bx,cy); ctx.stroke();
  ctx.setLineDash([]);

  // Amplitudes
  const a = Math.cos(theta/2), b = Math.sin(theta/2);
  ctx.fillStyle='#2c5282'; ctx.font='13px IBM Plex Mono'; ctx.textAlign='left';
  ctx.fillText(`α = cos(θ/2) = ${a.toFixed(3)}`, 12, H-42);
  ctx.fillText(`β = sin(θ/2)·e^{jφ}, |β|=${b.toFixed(3)}`, 12, H-24);
  ctx.fillStyle='#888'; ctx.font='11px IBM Plex Mono';
  ctx.fillText(`P(|0⟩)=${(a*a).toFixed(3)}, P(|1⟩)=${(b*b).toFixed(3)}`, W-160, H-10);
}
updateBloch();

// ── BELL CANVAS ────────────────────────────────────────────────
const bellNames = ['|Φ⁺⟩','|Φ⁻⟩','|Ψ⁺⟩','|Ψ⁻⟩'];
const bellOutcomes = ['00','01','10','11'];
const bellCols = ['#2c5282','#1a6b3a','#b7530a','#c0392b'];
let bellHistory = [];

function simBell(idx) {
  bellHistory.push({state:idx, outcome:bellOutcomes[idx]});
  drawBell();
}

function resetBell() { bellHistory = []; drawBell(); }

function drawBell() {
  const cv = document.getElementById('cBell');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

  // Draw table headers
  const col = [60,180,340,460];
  const headers = ['Bell state input','Outcome','Bell state →','Result'];
  ctx.fillStyle='#2c5282'; ctx.font='bold 11px IBM Plex Mono'; ctx.textAlign='center';
  headers.forEach((h,i) => ctx.fillText(h, col[i], 22));
  ctx.strokeStyle='#dedad0'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(20,28); ctx.lineTo(W-20,28); ctx.stroke();

  if(bellHistory.length===0) {
    ctx.fillStyle='#888'; ctx.font='13px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText('Click a Bell state button above to simulate a measurement', W/2, H/2+8);
    return;
  }

  const last5 = bellHistory.slice(-5);
  last5.forEach((item,i) => {
    const y = 52 + i*30;
    ctx.fillStyle = bellCols[item.state];
    ctx.font = '13px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText(bellNames[item.state], col[0], y);
    ctx.fillStyle = '#1a1a14';
    ctx.fillText('→', col[1]-40, y);
    ctx.fillStyle = '#c0392b'; ctx.font='bold 14px IBM Plex Mono';
    ctx.fillText(item.outcome, col[1]+20, y);
    ctx.fillStyle='#888'; ctx.font='11px IBM Plex Mono';
    ctx.fillText('detected', col[2], y);
    ctx.fillStyle = bellCols[item.state];
    ctx.fillText(bellNames[item.state], col[3], y);
  });
}
drawBell();

// ── TELEPORTATION CANVAS ───────────────────────────────────────
let teleState = null;

function updateTele() {
  const theta = parseFloat(document.getElementById('slTeleTheta').value);
  document.getElementById('teleThetaVal').textContent = theta+'°';
  teleState = null;
  drawTele(null);
}

function runTele() {
  const theta = parseFloat(document.getElementById('slTeleTheta').value)*Math.PI/180;
  const alpha = Math.cos(theta/2), beta = Math.sin(theta/2);
  // Simulate random measurement
  const outcomes = ['00','01','10','11'];
  const corrections = ['I (none)','Z gate','X gate','X then Z'];
  const idx = Math.floor(Math.random()*4);
  teleState = {alpha, beta, theta:theta*180/Math.PI, outcome:outcomes[idx], corr:corrections[idx]};
  drawTele(teleState);
  document.getElementById('teleResult').textContent =
    `Alice measured "${outcomes[idx]}" → Bob applies ${corrections[idx]} → recovers |ψ⟩ ✓`;
}

function resetTele() {
  teleState = null;
  document.getElementById('teleResult').textContent = '';
  drawTele(null);
}

function drawTele(state) {
  const cv = document.getElementById('cTele');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

  // Draw protocol diagram
  const y1=70, y2=120, y3=170; // Alice qubit, Alice Bell qubit, Bob qubit
  const stages = [80, 200, 330, 450];

  // Labels
  ctx.fillStyle='#c0392b'; ctx.font='bold 12px IBM Plex Sans'; ctx.textAlign='right';
  ctx.fillText('|ψ⟩ →', stages[0]-5, y1+4);
  ctx.fillStyle='#2c5282';
  ctx.fillText('|Φ⁺⟩ {', stages[0]-5, y2+4);
  ctx.fillStyle='#1a6b3a'; ctx.textAlign='left';
  ctx.fillText('Bob', stages[3]+40, y3+4);

  // Wires
  ctx.strokeStyle='#ccc8ba'; ctx.lineWidth=2;
  [[y1],[y2],[y3]].forEach(([y]) => {
    ctx.beginPath(); ctx.moveTo(stages[0],y); ctx.lineTo(stages[3],y); ctx.stroke();
  });

  // CNOT (Alice: q_in → q0)
  ctx.strokeStyle='#c0392b'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(stages[1],y1); ctx.lineTo(stages[1],y2); ctx.stroke();
  ctx.fillStyle='#c0392b';
  ctx.beginPath(); ctx.arc(stages[1],y1,6,0,2*Math.PI); ctx.fill();
  ctx.beginPath(); ctx.arc(stages[1],y2,10,0,2*Math.PI); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(stages[1]-10,y2); ctx.lineTo(stages[1]+10,y2); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(stages[1],y2-10); ctx.lineTo(stages[1],y2+10); ctx.stroke();

  // H gate
  ctx.fillStyle='white'; ctx.strokeStyle='#2c5282'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.roundRect(stages[2]-20,y1-18,40,36,4); ctx.fill(); ctx.stroke();
  ctx.fillStyle='#2c5282'; ctx.font='bold 18px IBM Plex Mono'; ctx.textAlign='center';
  ctx.fillText('H', stages[2], y1+6);

  // Measurements
  [y1,y2].forEach(y => {
    ctx.fillStyle='#f8f6ef'; ctx.strokeStyle='#888'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.roundRect(stages[3]-20,y-15,35,30,3); ctx.fill(); ctx.stroke();
    ctx.fillStyle='#888'; ctx.font='18px sans-serif'; ctx.textAlign='center';
    ctx.fillText('M', stages[3]-2, y+6);
  });

  // Correction box on Bob
  if(state) {
    ctx.fillStyle='#d1fae5'; ctx.strokeStyle='#1a6b3a'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.roundRect(stages[3]-20,y3-18,70,36,4); ctx.fill(); ctx.stroke();
    ctx.fillStyle='#1a6b3a'; ctx.font='bold 13px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText(state.corr.slice(0,8), stages[3]+15, y3+5);
  }

  // State labels
  if(state) {
    ctx.fillStyle='#c0392b'; ctx.font='12px IBM Plex Mono'; ctx.textAlign='left';
    ctx.fillText(`α=${state.alpha.toFixed(2)}, β=${state.beta.toFixed(2)}`, 10, H-10);
    ctx.fillStyle='#888';
    ctx.fillText(`Alice→"${state.outcome}"→ Bob corrects`, 180, H-10);
  } else {
    ctx.fillStyle='#888'; ctx.font='11px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText('Set θ for Alice\'s state, then click Run Protocol', W/2, H-10);
  }
}
drawTele(null);

// ── TOMOGRAPHY CANVAS ──────────────────────────────────────────
function runTomography() {
  const theta = parseFloat(document.getElementById('slTomoTheta').value)*Math.PI/180;
  const phiDeg = parseFloat(document.getElementById('slTomoPhi').value);
  const phi = phiDeg*Math.PI/180;

  const alpha = Math.cos(theta/2);          // real, ≥ 0
  const betaR = Math.sin(theta/2)*Math.cos(phi - Math.PI/2);
  const betaI = Math.sin(theta/2)*Math.sin(phi - Math.PI/2);

  const N = 2000; // simulated shots
  // Measurement 1 — Z basis
  let N0z = 0;
  for(let i=0;i<N;i++) if(Math.random()<alpha*alpha) N0z++;
  const alphaEst = Math.sqrt(N0z/N);
  const betaMagEst = Math.sqrt(1-N0z/N);

  // Measurement 2 — X basis (after H)
  // P("0") = (1+2α·βR)/2
  const pX = (1 + 2*alpha*betaR)/2;
  let N0x = 0;
  for(let i=0;i<N;i++) if(Math.random()<pX) N0x++;
  const betaREst = (2*N0x/N - 1)/(2*alphaEst||1);

  // Measurement 3 — Y basis (after S†·H)
  // P("0") = (1+2α·βI)/2
  const pY = (1 + 2*alpha*betaI)/2;
  let N0y = 0;
  for(let i=0;i<N;i++) if(Math.random()<pY) N0y++;
  const betaIEst = (2*N0y/N - 1)/(2*alphaEst||1);

  drawTomography({
    alpha, betaR, betaI,
    alphaEst, betaREst, betaIEst,
    N0z, N0x, N0y, N,
    theta: theta*180/Math.PI, phi: phiDeg
  });
}

function drawTomography(d) {
  const cv = document.getElementById('cTomo');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  const W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f8f6ef'; ctx.fillRect(0,0,W,H);

  if(!d) {
    ctx.fillStyle='#888'; ctx.font='13px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText('Set the true state parameters and click "Run Tomography"', W/2, H/2);
    return;
  }

  const cols = ['#2c5282','#b7530a','#1a6b3a'];
  const labels = ['Z-basis → α','X-basis → βR','Y-basis → βI'];
  const trueVals = [d.alpha, d.betaR, d.betaI];
  const estVals  = [d.alphaEst, d.betaREst, d.betaIEst];
  const N0s = [d.N0z, d.N0x, d.N0y];

  const bw=120, gap=40, startX=50, yBase=H-30;

  labels.forEach((lbl,i) => {
    const x = startX + i*(bw+gap);
    const maxH = 120;
    const hTrue = Math.abs(trueVals[i])*maxH;
    const hEst  = Math.abs(estVals[i])*maxH;
    const neg = trueVals[i] < 0;

    // True bar (light)
    ctx.fillStyle = cols[i]+'44';
    ctx.fillRect(x, neg ? yBase - maxH/2 : yBase-hTrue, bw, neg ? hTrue - maxH/2 : hTrue);

    // Estimated bar (solid, inset)
    ctx.fillStyle = cols[i];
    const hE2 = Math.abs(estVals[i])*maxH;
    const negE = estVals[i] < 0;
    ctx.fillRect(x+15, negE ? yBase - maxH/2 : yBase-hE2, bw-30, negE ? hE2 - maxH/2 : hE2);

    // Zero line
    ctx.strokeStyle='#999'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x,yBase); ctx.lineTo(x+bw,yBase); ctx.stroke();

    // Labels
    ctx.fillStyle='#1a1a14'; ctx.font='bold 11px IBM Plex Mono'; ctx.textAlign='center';
    ctx.fillText(lbl, x+bw/2, 14);
    ctx.fillStyle=cols[i]; ctx.font='12px IBM Plex Mono';
    ctx.fillText(`true: ${trueVals[i].toFixed(3)}`, x+bw/2, H-12);
    ctx.fillStyle='#555';
    ctx.fillText(`est:  ${estVals[i].toFixed(3)}`, x+bw/2, yBase+14);
    ctx.fillStyle='#888'; ctx.font='10px IBM Plex Mono';
    ctx.fillText(`N₀=${N0s[i]}/${d.N}`, x+bw/2, H-28);
  });

  // Legend
  ctx.fillStyle='#bbb'; ctx.fillRect(W-130,8,14,12);
  ctx.fillStyle='#555'; ctx.font='10px IBM Plex Mono'; ctx.textAlign='left';
  ctx.fillText('true value',W-113,19);
  ctx.fillStyle='#555'; ctx.fillRect(W-130,24,14,12);
  ctx.fillText('estimated',W-113,35);
}

function updateTomoSliders() {
  document.getElementById('tomoThetaVal').textContent = document.getElementById('slTomoTheta').value+'°';
  document.getElementById('tomoPhiVal').textContent   = document.getElementById('slTomoPhi').value+'°';
}

drawTomography(null);

</script>
