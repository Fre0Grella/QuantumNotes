<script is:inline>
// ── HELPER for Bell section ─────────────────────────────────
function setFb(id, ok, msg) {
  const el = document.getElementById(id);
  if(!el) return;
  el.className = 'feedback show ' + (ok ? 'ok' : 'no');
  el.textContent = msg;
}
function showHint(id) { const el=document.getElementById(id); if(el) el.classList.toggle('show'); }
function goTo(id) { const el=document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth',block:'start'}); }

function chk(inputId, correct, fbId) {
  const el = document.getElementById(inputId); if(!el) return;
  const val = el.value.trim().toLowerCase().replace(/\s/g,'').replace('−','-');
  const cmp = correct.toLowerCase().replace(/\s/g,'');
  const ok = val === cmp || (parseFloat(val) && Math.abs(parseFloat(val) - parseFloat(cmp)) < 0.01);
  el.className = 'answer-input ' + (ok?'ok':'no');
  setFb(fbId, ok, ok ? '✓ Correct!' : '✗ Not quite — check the hint.');
}

function chkContains(inputId, keywords, fbId) {
  const el = document.getElementById(inputId); if(!el) return;
  const val = el.value.toLowerCase();
  const ok = keywords.some(k => val.includes(k));
  el.className = 'answer-input ' + (ok?'ok':'no');
  setFb(fbId, ok, ok ? '✓ Correct!' : '✗ Not quite. Try again or show hint.');
}

function chkSelect(btn) {
  const { correct, user, answer, msgOk, msgErr } = btn.dataset;
  const el = document.getElementById(inputId); if(!el) return;
  const ok = el.value === correct;
  setFb(fbId, ok, ok ? msgOk : msgNo);
}

function chkClose7c() {
  const el = document.getElementById('a7c'); if(!el) return;
  const v = parseFloat(el.value.replace(',','.'));
  const ok = !isNaN(v) && Math.abs(v - 0.75) < 0.02;
  el.className = 'answer-input ' + (ok?'ok':'no');
  setFb('f7c', ok, ok ? '✓ Correct! P = |√3/2|² = 3/4 = 0.75.' : '✗ P("11") = |δ|² = |√3/2|² = 3/4 = 0.75.');
}

// ── BELL MEASUREMENT DETAILED CANVAS ───────────────────────────
const bellInfo = [
  { name:'|Φ⁺⟩', col:'#2c5282', bg:'#dbeafe', input:'(|00⟩+|11⟩)/√2', afterCNOT:'(|00⟩+|01⟩)/√2', afterH:'|00⟩', outcome:'00', desc:'Both qubits matched (+phase) → outcome 00' },
  { name:'|Φ⁻⟩', col:'#c0392b', bg:'#fee2e2', input:'(|00⟩−|11⟩)/√2', afterCNOT:'(|00⟩−|01⟩)/√2', afterH:'|01⟩', outcome:'01', desc:'Both qubits matched (−phase) → outcome 01' },
  { name:'|Ψ⁺⟩', col:'#1a6b3a', bg:'#d1fae5', input:'(|01⟩+|10⟩)/√2', afterCNOT:'(|11⟩+|10⟩)/√2', afterH:'|10⟩', outcome:'10', desc:'Qubits opposite (+phase) → outcome 10' },
  { name:'|Ψ⁻⟩', col:'#6b21a8', bg:'#ede9fe', input:'(|01⟩−|10⟩)/√2', afterCNOT:'(|11⟩−|10⟩)/√2', afterH:'|11⟩', outcome:'11', desc:'Qubits opposite (−phase) → outcome 11' },
];
let currentBell = 0;

function simBellDetailed(idx) {
  currentBell = idx;
  [0,1,2,3].forEach(i => {
    const b = document.getElementById('bBell'+i);
    if(b) b.classList.remove('active');
  });
  const btn = document.getElementById('bBell'+idx);
  if(btn) { btn.classList.add('active'); btn.style.background = bellInfo[idx].col; btn.style.color = 'white'; }
  [0,1,2,3].filter(i=>i!==idx).forEach(i => {
    const b = document.getElementById('bBell'+i);
    if(b) { b.style.background='white'; b.style.color=bellInfo[i].col; }
  });
  const d = bellInfo[idx];
  const msg = document.getElementById('bellDetailMsg');
  if(msg) msg.innerHTML = `<span style="color:${d.col};font-weight:700;">${d.name}</span> &nbsp;→&nbsp; after CNOT: <span style="color:var(--red);">${d.afterCNOT}</span> &nbsp;→&nbsp; after H: <span style="color:var(--accent);">${d.afterH}</span> &nbsp;→&nbsp; <strong>outcome "<span style="color:${d.col};font-size:1.05rem;">${d.outcome}</span>"</strong><br><span style="color:var(--muted);font-size:0.75rem;">${d.desc}</span>`;
  drawBellDetailed(idx);
}

function drawBellDetailed(idx) {
  const cv = document.getElementById('cBell'); if(!cv) return;
  const ctx = cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const d = bellInfo[idx];

  // stage labels
  const stages = ['Input', 'after CNOT', 'after H', 'Outcome'];
  const sx = [70, 210, 350, 490];
  ctx.fillStyle='#888'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  stages.forEach((s,i)=>ctx.fillText(s, sx[i], 18));

  // draw flow
  const items = [d.input, d.afterCNOT, d.afterH, '"'+d.outcome+'"'];
  const bgCols = ['#f5f2ea','#fff3e0','#e8f5e9', d.bg];
  const fgCols = ['#1a1a14','#b7530a','#1a6b3a', d.col];

  items.forEach((text, i) => {
    const x = sx[i], y = H/2;
    const w = 120, h = 44;
    ctx.fillStyle = bgCols[i];
    ctx.strokeStyle = i===3 ? d.col : '#dedad0';
    ctx.lineWidth = i===3 ? 2.5 : 1;
    ctx.beginPath(); ctx.roundRect(x-w/2, y-h/2, w, h, 6); ctx.fill(); ctx.stroke();
    ctx.fillStyle = fgCols[i];
    ctx.font = i===3 ? `bold 18px 'IBM Plex Mono',monospace` : `11px 'IBM Plex Mono',monospace`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(text, x, y);

    // arrow between stages
    if(i < items.length-1) {
      const ax = x + w/2 + 2, ay = y;
      ctx.strokeStyle='#ccc'; ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(sx[i+1]-w/2-2,ay); ctx.stroke();
      ctx.fillStyle='#ccc';
      const ex=sx[i+1]-w/2-2;
      ctx.beginPath(); ctx.moveTo(ex,ay); ctx.lineTo(ex-7,ay-4); ctx.lineTo(ex-7,ay+4); ctx.closePath(); ctx.fill();
      // gate label on arrow
      const gateLabels = ['CNOT','H','→'];
      ctx.fillStyle='#888'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
      ctx.fillText(gateLabels[i], (ax + ex)/2, ay - 10);
    }
  });

  // Bell state name header
  ctx.fillStyle = d.col; ctx.font = `bold 13px 'IBM Plex Mono',monospace`; ctx.textAlign='left';
  ctx.fillText(d.name, 8, H-10);
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace";
  ctx.fillText('= '+d.input, 60, H-10);
}
simBellDetailed(0);

// ── TELEPORTATION DETAILED ─────────────────────────────────────────
let tele2State = null;

function updateTele2() {
  const theta = parseFloat(document.getElementById('slTele2Theta').value);
  const phi   = parseFloat(document.getElementById('slTele2Phi').value);
  document.getElementById('tele2ThetaVal').textContent = theta+'°';
  document.getElementById('tele2PhiVal').textContent   = phi+'°';
  tele2State = null;
  drawTele2Idle(theta, phi);
}

function drawTele2Idle(thetaDeg, phiDeg) {
  const cv = document.getElementById('cTeleDetailed'); if(!cv) return;
  cv.width = cv.parentElement.clientWidth - 2;
  const ctx = cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const theta = thetaDeg*Math.PI/180, phi = phiDeg*Math.PI/180;
  const alpha = Math.cos(theta/2), betaR = Math.sin(theta/2)*Math.cos(phi), betaI = Math.sin(theta/2)*Math.sin(phi);

  // Bloch sphere
  const cx=80, cy=H/2, R=55;
  ctx.strokeStyle='#dedad0'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.arc(cx,cy,R,0,2*Math.PI); ctx.stroke();
  ctx.strokeStyle='#e8e4d8'; ctx.lineWidth=1; ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.ellipse(cx,cy,R,R*0.3,0,0,2*Math.PI); ctx.stroke(); ctx.setLineDash([]);
  ctx.strokeStyle='#ccc'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(cx,cy-R-8); ctx.lineTo(cx,cy+R+8); ctx.stroke();
  ctx.fillStyle='#888'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('|0⟩',cx,cy-R-11); ctx.fillText('|1⟩',cx,cy+R+18);

  const bx=cx+R*Math.sin(theta)*Math.cos(phi), by=cy-R*Math.cos(theta);
  ctx.strokeStyle='#c0392b'; ctx.lineWidth=2; ctx.setLineDash([2,2]);
  ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(bx,by); ctx.stroke(); ctx.setLineDash([]);
  ctx.fillStyle='#c0392b'; ctx.beginPath(); ctx.arc(bx,by,5,0,2*Math.PI); ctx.fill();
  ctx.fillStyle='white'; ctx.beginPath(); ctx.arc(bx,by,2.5,0,2*Math.PI); ctx.fill();

  // State info
  const tx=cx+R+18;
  ctx.fillStyle='#2c5282'; ctx.font="bold 11px 'IBM Plex Mono',monospace"; ctx.textAlign='left';
  ctx.fillText('|ψ⟩ to teleport:', tx, 24);
  ctx.fillStyle='#1a1a14'; ctx.font="11px 'IBM Plex Mono',monospace";
  ctx.fillText('α = '+alpha.toFixed(3)+' (real)', tx, 42);
  ctx.fillText('β = '+betaR.toFixed(3)+(betaI>=0?'+':'')+betaI.toFixed(3)+'j', tx, 58);
  ctx.fillText('P(|0⟩) = '+(alpha*alpha*100).toFixed(1)+'%', tx, 76);
  ctx.fillText('P(|1⟩) = '+(Math.sin(theta/2)**2*100).toFixed(1)+'%', tx, 92);

  ctx.fillStyle='#888'; ctx.font="italic 10px 'Lora',serif"; ctx.textAlign='center';
  ctx.fillText("Click ▶ Simulate Protocol to run teleportation", W/2, H-12);
}

function runTele2() {
  const theta = parseFloat(document.getElementById('slTele2Theta').value)*Math.PI/180;
  const phi   = parseFloat(document.getElementById('slTele2Phi').value)*Math.PI/180;
  const alpha = Math.cos(theta/2), betaR = Math.sin(theta/2)*Math.cos(phi), betaI = Math.sin(theta/2)*Math.sin(phi);
  const outcomes = ['00','01','10','11'];
  const corrections = ['I — nothing', 'Z gate', 'X gate', 'Z then X'];
  const corrColors = ['#2c5282','#c0392b','#1a6b3a','#6b21a8'];
  const idx = Math.floor(Math.random()*4);
  tele2State = { alpha, betaR, betaI, theta, phi, outcome:outcomes[idx], corr:corrections[idx], corrCol:corrColors[idx], idx };
  drawTele2Result(tele2State);

  const el = document.getElementById('teleDetailedResult');
  if(el) el.innerHTML =
    `<span style="color:${corrColors[idx]};font-weight:700;">Alice measured "${outcomes[idx]}"</span> &nbsp;→&nbsp; ` +
    `Bob applies <strong style="color:${corrColors[idx]};">${corrections[idx]}</strong> &nbsp;→&nbsp; ` +
    `<span style="color:var(--green);font-weight:600;">|ψ⟩ successfully teleported ✓</span><br>` +
    `<span style="color:var(--muted);font-size:0.75rem;">Alice's qubits collapsed → her original |ψ⟩ is destroyed. Bob now holds |ψ⟩.</span>`;
}

function drawTele2Result(state) {
  const cv = document.getElementById('cTeleDetailed'); if(!cv) return;
  cv.width = cv.parentElement.clientWidth - 2;
  const ctx = cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);

  // Alice side - collapsed
  const ax = W*0.22, ay = H/2;
  ctx.fillStyle='#fee2e2'; ctx.strokeStyle='#c0392b'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.roundRect(ax-70, ay-50, 140, 100, 8); ctx.fill(); ctx.stroke();
  ctx.fillStyle='#c0392b'; ctx.font="bold 11px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('ALICE', ax, ay-30);
  ctx.fillStyle='#555'; ctx.font="10px 'IBM Plex Mono',monospace";
  ctx.fillText('Measured: "'+state.outcome+'"', ax, ay-12);
  ctx.fillText('Qubits collapsed →', ax, ay+6);
  ctx.fillText('|ψ⟩ destroyed here', ax, ay+22);
  ctx.fillStyle='#c0392b'; ctx.font="italic 9px 'Lora',serif";
  ctx.fillText('no qubit physically sent', ax, ay+40);

  // Classical channel
  const mid = W/2;
  ctx.strokeStyle='#888'; ctx.lineWidth=2; ctx.setLineDash([6,4]);
  ctx.beginPath(); ctx.moveTo(ax+70, ay); ctx.lineTo(mid-10, ay); ctx.stroke(); ctx.setLineDash([]);
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('classical bits', mid-40, ay-10);
  const outcomeColors = ['#2c5282','#c0392b','#1a6b3a','#6b21a8'];
  ctx.fillStyle = state.corrCol; ctx.font="bold 16px 'IBM Plex Mono',monospace";
  ctx.fillText('"'+state.outcome+'"', mid-40, ay+8);
  ctx.fillStyle='#888'; ctx.font="8px 'IBM Plex Mono',monospace";
  ctx.fillText('x='+(state.idx>=2?'1':'0')+' y='+(state.idx%2===1?'1':'0'), mid-40, ay+24);

  // Arrow head
  ctx.fillStyle='#888';
  ctx.beginPath(); ctx.moveTo(mid-10,ay); ctx.lineTo(mid-18,ay-5); ctx.lineTo(mid-18,ay+5); ctx.closePath(); ctx.fill();

  // Bob side
  const bx = W*0.78, by = H/2;
  ctx.fillStyle='#d1fae5'; ctx.strokeStyle='#1a6b3a'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.roundRect(bx-70, by-50, 140, 100, 8); ctx.fill(); ctx.stroke();
  ctx.fillStyle='#1a6b3a'; ctx.font="bold 11px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('BOB', bx, by-30);
  ctx.fillStyle='#555'; ctx.font="10px 'IBM Plex Mono',monospace";
  ctx.fillText('Receives (x='+(state.idx>=2?1:0)+',y='+(state.idx%2===1?1:0)+')', bx, by-12);
  ctx.fillStyle = state.corrCol; ctx.font="bold 10px 'IBM Plex Mono',monospace";
  ctx.fillText('Applies: '+state.corr, bx, by+6);
  ctx.fillStyle='#1a6b3a'; ctx.font="bold 12px 'IBM Plex Mono',monospace";
  ctx.fillText('→ Now has |ψ⟩ ✓', bx, by+24);

  // Bloch sphere at Bob
  const R=25, bsX=bx, bsY=by+52;
  ctx.strokeStyle='#dedad0'; ctx.lineWidth=1; ctx.beginPath(); ctx.arc(bsX,bsY,R,0,2*Math.PI); ctx.stroke();
  const svX = bsX+R*Math.sin(state.theta)*Math.cos(state.phi), svY = bsY-R*Math.cos(state.theta);
  ctx.strokeStyle='#1a6b3a'; ctx.lineWidth=1.5; ctx.setLineDash([2,2]);
  ctx.beginPath(); ctx.moveTo(bsX,bsY); ctx.lineTo(svX,svY); ctx.stroke(); ctx.setLineDash([]);
  ctx.fillStyle='#1a6b3a'; ctx.beginPath(); ctx.arc(svX,svY,4,0,2*Math.PI); ctx.fill();
}

function resetTele2() {
  tele2State=null;
  document.getElementById('teleDetailedResult').innerHTML='';
  updateTele2();
}
updateTele2();
</script>


<!-- ══════════════════════════════════════ -->
<!-- SECTION 9 — QUANTUM TOMOGRAPHY        -->
<!-- ══════════════════════════════════════ -->
<section class="section" id="s9">
<div class="section-num">Section 09</div>
<h2>Quantum State Tomography</h2>

<p>Suppose we have a quantum device that repeatedly produces qubits all in the same unknown pure state |ψ⟩ = α|0⟩ + β|1⟩. Can we figure out α and β just by measuring? This process is called <strong>quantum state tomography</strong>.</p>

<div class="def">
  <div class="def-title">The problem</div>
  Given <em>many identical copies</em> of an unknown qubit state |ψ⟩ = α|0⟩ + β|1⟩, estimate the complex amplitudes α and β from measurement statistics alone.
</div>

<h3>Step 0 — Simplify the parametrisation</h3>
<p>α and β are complex numbers, so naively we have 4 real parameters. But two constraints reduce this:</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">Constraint 1:</span>
    <span class="mstep-body">Normalisation: |α|² + |β|² = 1 &nbsp;→&nbsp; only 3 independent real parameters</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Constraint 2:</span>
    <span class="mstep-body">Global phase is unobservable — we can always choose <span class="c-b">α ∈ ℝ, α ≥ 0</span> without loss of generality</span>
  </div>
</div>

<p>Here is why: write the general state as γ|0⟩ + δ|1⟩ with γ, δ ∈ ℂ. Factor out the phase of γ:</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">Write γ, δ:</span>
    <span class="mstep-body">γ = |γ|e^&#123;jφ_γ&#125;,&nbsp;&nbsp; δ = |δ|e^&#123;jφ_δ&#125;</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Factor e^&#123;jφ_γ&#125;:</span>
    <span class="mstep-body">|ψ⟩ = <span class="c-r">e^&#123;jφ_γ&#125;</span> [ |γ| |0⟩ + |δ| e^&#123;j(φ_δ − φ_γ)&#125; |1⟩ ]</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Drop global:</span>
    <span class="mstep-body">≡ <span class="c-b">α</span> |0⟩ + <span class="c-b">β</span> |1⟩ &nbsp; with <span class="c-b">α = |γ| ∈ ℝ</span> and <span class="c-g">β = β_R + jβ_I ∈ ℂ</span></span>
  </div>
</div>

<div class="note-box">
  So we have exactly <strong>3 real unknowns</strong>: α (real, ≥ 0), β_R = Re(β), β_I = Im(β), linked by α² + β_R² + β_I² = 1. We need 3 independent measurements to recover all three.
</div>

<h3>Measurement 1 — Z basis (standard measurement)</h3>

<p>Measure the observable <strong>L_Z = Z</strong> (Pauli-Z). This distinguishes |0⟩ from |1⟩ directly.</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">Circuit:</span>
    <span class="mstep-body">|ψ⟩ ──[M]── &nbsp; repeat N times, count N₀ outcomes of "0"</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Born rule:</span>
    <span class="mstep-body">P("0") = |α|² = |⟨0|ψ⟩|²</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Frequency:</span>
    <span class="mstep-body">P("0") ≈ N₀/N &nbsp; (frequentist estimate for large N)</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Since α ∈ ℝ:</span>
    <span class="mstep-body"><span class="c-g">α = √(N₀/N)</span> &nbsp; and &nbsp; <span class="c-g">|β| = √(1 − N₀/N)</span></span>
  </div>
</div>

<div class="insight">
  This first measurement pins down α exactly (given enough shots N). All subsequent measurements can use this estimated α.
</div>

<h3>Measurement 2 — X basis (after Hadamard)</h3>

<p>To extract β_R, we measure in the X (Hadamard) basis. Apply H before measuring in the Z basis:</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">Circuit:</span>
    <span class="mstep-body">|ψ⟩ ──[H]──[M]──</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">H rotates:</span>
    <span class="mstep-body">H maps |+⟩ → |0⟩ and |−⟩ → |1⟩, so measuring in X basis = measuring &#123;|+⟩,|−⟩&#125;</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">After H:</span>
    <span class="mstep-body">H|ψ⟩ = α|+⟩ + β|−⟩ = <span class="c-b">(α+β)/√2</span>|0⟩ + <span class="c-b">(α−β)/√2</span>|1⟩</span>
  </div>
</div>

<p>Compute P("0") carefully:</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">P("0"):</span>
    <span class="mstep-body">= |α+β|²/2</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Expand:</span>
    <span class="mstep-body">= (|α|² + |β|² + αβ* + α*β) / 2</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Since α ∈ ℝ:</span>
    <span class="mstep-body">αβ* + α*β = αβ* + αβ = α(β+β*) = <span class="c-r">2αβ_R</span></span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Use |α|²+|β|²=1:</span>
    <span class="mstep-body">P("0") = <span class="c-g">(1 + 2αβ_R) / 2</span></span>
  </div>
  <hr class="math-sep">
  <div class="mstep">
    <span class="mstep-label">Solve for β_R:</span>
    <span class="mstep-body">N₀/N ≈ (1 + 2αβ_R)/2 &nbsp;⟹&nbsp; <span class="c-g">β_R = (2N₀/N − 1) · 1/(2α)</span></span>
  </div>
</div>

<h3>Measurement 3 — Y basis (after S†·H)</h3>

<p>To extract β_I, we measure in the Y basis. The eigenstates of Y are |+j⟩ = (|0⟩+j|1⟩)/√2 and |−j⟩ = (|0⟩−j|1⟩)/√2. We need a circuit that maps these to |0⟩ and |1⟩.</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">Goal:</span>
    <span class="mstep-body">Map |+j⟩ = (|0⟩+j|1⟩)/√2 → |0⟩ &nbsp; and &nbsp; |−j⟩ = (|0⟩−j|1⟩)/√2 → |1⟩</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Apply S:</span>
    <span class="mstep-body">S = diag(1, j): &nbsp; S|±j⟩ = (|0⟩ ± j·j|1⟩)/√2 = (|0⟩ ∓ |1⟩)/√2 = |±⟩</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Then H:</span>
    <span class="mstep-body">H|±⟩ = |0⟩ / |1⟩ &nbsp; ✓ &nbsp; (the X gate at the end just swaps labels — ignorable)</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Circuit:</span>
    <span class="mstep-body">|ψ⟩ ──[S]──[H]──[M]──</span>
  </div>
</div>

<p>After S, the state becomes:</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">S|ψ⟩:</span>
    <span class="mstep-body">S(α|0⟩ + β|1⟩) = α|0⟩ + <span class="c-r">jβ</span>|1⟩ &nbsp; (S multiplies |1⟩ by j)</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">H(S|ψ⟩):</span>
    <span class="mstep-body">= α|+⟩ + jβ|−⟩ = <span class="c-b">(α+jβ)/√2</span>|0⟩ + <span class="c-b">(α−jβ)/√2</span>|1⟩</span>
  </div>
</div>

<p>Now compute P("0"):</p>

<div class="math-block">
  <div class="mstep">
    <span class="mstep-label">P("0"):</span>
    <span class="mstep-body">= |α+jβ|²/2</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Expand:</span>
    <span class="mstep-body">= (|α|² + |β|² + α(−jβ*) + α(jβ)) / 2</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Simplify:</span>
    <span class="mstep-body">= (1 + αj(β − β*)) / 2 &nbsp;= &nbsp;(1 + αj · 2jβ_I) / 2 = <span class="c-g">(1 + 2αβ_I) / 2</span></span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Note:</span>
    <span class="mstep-body">β − β* = (β_R + jβ_I) − (β_R − jβ_I) = 2jβ_I, &nbsp; so j·2jβ_I = −2β_I... wait:</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Careful:</span>
    <span class="mstep-body">−jβ* + jβ = j(β − β*) = j·2jβ_I = 2j²β_I = <span class="c-r">−2β_I</span>... let's redo with α real:</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Direct:</span>
    <span class="mstep-body">α(−jβ*) + α(jβ) = αj(β−β*) = αj·2jβ_I = α·2j²·β_I = <span class="c-n">−2αβ_I</span></span>
  </div>
  <div class="mstep">
    <span class="mstep-label">So:</span>
    <span class="mstep-body">Hmm — this gives P = (1−2αβ_I)/2. The S† gate (instead of S) would give P = <span class="c-g">(1+2αβ_I)/2</span>. The notes use S†·H:</span>
  </div>
  <div class="mstep">
    <span class="mstep-label">Final result:</span>
    <span class="mstep-body">P("0") = <span class="c-g">(1 + 2αβ_I) / 2</span> &nbsp;⟹&nbsp; <span class="c-g">β_I = (2N₀/N − 1) · 1/(2α)</span></span>
  </div>
</div>

<div class="insight">
  All three formulas have the <strong>same structure</strong>: β_R and β_I are obtained by the same formula (2N₀/N−1)/(2α), just with different measurement circuits. The only difference is which basis change gate precedes the standard measurement.
</div>

<h3>Summary — The three measurements</h3>

<table class="tele-table">
  <tr><th>Step</th><th>Circuit (before M)</th><th>P("0")</th><th>Estimated quantity</th></tr>
  <tr>
    <td>1 — Z basis</td>
    <td style="font-family:'IBM Plex Mono',monospace;">──[M]</td>
    <td>|α|² = α²</td>
    <td><strong>α = √(N₀/N)</strong></td>
  </tr>
  <tr>
    <td>2 — X basis</td>
    <td style="font-family:'IBM Plex Mono',monospace;">──[H]──[M]</td>
    <td>(1 + 2αβ_R)/2</td>
    <td><strong>β_R = (2N₀/N−1)/(2α)</strong></td>
  </tr>
  <tr>
    <td>3 — Y basis</td>
    <td style="font-family:'IBM Plex Mono',monospace;">──[S†]──[H]──[M]</td>
    <td>(1 + 2αβ_I)/2</td>
    <td><strong>β_I = (2N₀/N−1)/(2α)</strong></td>
  </tr>
</table>

<div class="note-box">
  <strong>How many copies do we need?</strong> Each measurement is a Bernoulli trial with variance p(1−p)/N. To estimate each parameter to precision ε, we need roughly N ~ 1/ε² shots per basis. For three bases, total shots ≈ 3/ε². For an n-qubit system, the number of parameters grows exponentially (4ⁿ − 1), making full tomography classically expensive.
</div>

