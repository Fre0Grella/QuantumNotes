        <div style="display:flex;align-items:center;padding:0 0.3rem;gap:0.3rem;">
          <div style="height:2px;background:#6dd6a0;flex:1;"></div>
          <!-- CNOT target from q0 -->
          <div style="border:2px solid #6dd6a0;border-radius:50%;width:16px;height:16px;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:0.8rem;color:#6dd6a0;font-weight:700;flex-shrink:0;">⊕</div>
          <div style="height:2px;background:#6dd6a0;flex:1;"></div>
        </div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;">
          <div style="height:2px;background:#6dd6a0;flex:1;"></div>
          <div style="height:2px;background:none;border-top:2px dashed #555;flex:1;"></div>
        </div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;gap:0.3rem;">
          <div style="height:2px;background:none;border-top:2px dashed #555;flex:1;"></div>
          <div style="border:2px solid #c0392b;border-radius:3px;padding:0.1rem 0.3rem;font-family:'IBM Plex Mono',monospace;font-size:0.65rem;font-weight:700;color:#c0392b;flex-shrink:0;">X<sup style="font-size:0.55rem;color:#aaa;">if x=1</sup></div>
