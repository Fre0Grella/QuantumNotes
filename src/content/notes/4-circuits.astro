      <div style="display:grid;grid-template-columns:85px 1fr 1fr 1fr;align-items:center;gap:0;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:0.72rem;color:#2c5282;font-weight:600;">q₀ → Alice<br><span style="color:#7a8499;font-weight:300;font-size:0.62rem;">Bell pair</span></div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;gap:0.3rem;">
          <div style="height:2px;background:#a0cfff;flex:1;"></div>
          <div style="border:2px solid #fde68a;border-radius:3px;padding:0.1rem 0.3rem;font-family:'IBM Plex Mono',monospace;font-size:0.65rem;font-weight:700;color:#fde68a;flex-shrink:0;">H</div>
          <div style="height:2px;background:#a0cfff;flex:1;"></div>
          <div style="border:1.5px solid #a0cfff;border-radius:50%;width:10px;height:10px;background:#1a1a2e;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
            <div style="width:5px;height:1.5px;background:#a0cfff;"></div><div style="width:1.5px;height:5px;background:#a0cfff;position:absolute;"></div>
          </div>
          <div style="height:2px;background:#a0cfff;flex:1;"></div>
        </div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;gap:0.3rem;">
          <div style="height:2px;background:#a0cfff;flex:1;"></div>
          <!-- CNOT target from q_in -->
          <div style="border:2px solid #a0e0ff;border-radius:50%;width:16px;height:16px;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:0.8rem;color:#a0e0ff;font-weight:700;flex-shrink:0;">⊕</div>
          <div style="height:2px;background:#a0cfff;flex:1;"></div>
          <div style="border:1.5px solid #aaa;border-radius:3px;padding:0.1rem 0.3rem;font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:#aaa;flex-shrink:0;">M</div>
          <div style="height:2px;background:none;border-top:2px dashed #555;flex:1;"></div>
        </div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;gap:0.2rem;">
          <div style="height:2px;background:none;border-top:2px dashed #555;flex:1;"></div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:0.7rem;color:#2c5282;font-weight:700;flex-shrink:0;">y</div>
        </div>
      </div>

      <!-- connector line Bob's CNOT -->
      <div style="display:grid;grid-template-columns:85px 1fr 1fr 1fr;height:18px;">
        <div></div>
        <div style="display:flex;align-items:center;padding:0 0.3rem;">
          <div style="width:2px;height:100%;background:#a0cfff;margin-left:calc(100% - 14px);"></div>
