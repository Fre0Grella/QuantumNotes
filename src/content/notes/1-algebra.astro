function chkEigVerify(fb) {
  const a = document.getElementById('ae14a').value.trim().replace(/\s/g,'');
  const b = document.getElementById('ae14b').value.trim().toLowerCase();
  const v = 4/Math.SQRT2;
  const okA = isApprox(a, v, 0.01) || a==='4/√2' || a==='2√2' || a==='2*√2' || isApprox(a,2*Math.SQRT2,0.01);
  const okB = b.includes('yes')||b.includes('si')||b==='yes'||b==='s';
  document.getElementById('ae14a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ae14b').className='answer-input '+(okB?'ok':'no');
  const ok=okA&&okB;
  setFb(fb, ok,
    ok ? `✓ Correct! 4/√2 = 2√2 ≈ ${v.toFixed(3)}. And A|u₁⟩ = (2√2, 2√2)ᵀ = 4·(1/√2, 1/√2)ᵀ = 4·|u₁⟩ = λ|u₁⟩ ✓ The definition is verified!`
       : '✗ 4/√2 = 4·(1/√2) = 4·0.707 ≈ 2.828 = 2√2. And yes, A|u₁⟩ = 4·|u₁⟩ confirms it is an eigenvector with λ=4.');
  }

(function(){
  const c = document.getElementById('c_complex'); if(!c) return;
  function draw(re, im) {
    const {ctx,W,H} = clearC('c_complex')||{}; if(!ctx) return;
    const cx=W/2, cy=H/2, sc=70;
    drawAxes(ctx,W,H,cx,cy,sc,'Re','Im');
    ctx.fillStyle='#888877'; ctx.font='10px IBM Plex Mono,monospace';
    ctx.fillText('Re',W-22,cy-5); ctx.fillText('Im',cx+5,12);
    const mod = Math.sqrt(re*re+im*im);
    const phase = Math.atan2(im,re)*180/Math.PI;
    // phase arc
    if(mod>0.05){
      ctx.strokeStyle='rgba(183,83,10,0.35)'; ctx.lineWidth=1.2;
      ctx.beginPath(); ctx.arc(cx,cy,28,0,-Math.atan2(im,re), im>0); ctx.stroke();
      ctx.fillStyle='rgba(183,83,10,0.7)'; ctx.font='10px IBM Plex Mono,monospace';
      ctx.fillText(`φ=${phase.toFixed(0)}°`, cx+32, cy-5);
    }
    // dashed projections
    ctx.strokeStyle='rgba(136,136,119,0.3)'; ctx.lineWidth=1; ctx.setLineDash([3,3]);
    ctx.beginPath(); ctx.moveTo(cx+re*sc, cy-im*sc); ctx.lineTo(cx+re*sc, cy); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cx+re*sc, cy-im*sc); ctx.lineTo(cx, cy-im*sc); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='rgba(44,82,130,0.5)'; ctx.font='10px IBM Plex Mono,monospace';
    if(Math.abs(re)>0.1) ctx.fillText(`a=${re.toFixed(2)}`, cx+re*sc/2-12, cy+13);
    if(Math.abs(im)>0.1) ctx.fillText(`b=${im.toFixed(2)}`, cx+4, cy-im*sc/2+4);
    arrow(ctx,cx,cy,cx+re*sc,cy-im*sc,'#2c5282','z',2.5);
    // dot on tip
    ctx.beginPath(); ctx.arc(cx+re*sc,cy-im*sc,4,0,Math.PI*2);
    ctx.fillStyle='#2c5282'; ctx.fill();
    // info
    ctx.fillStyle='#1a1a14'; ctx.font='11px IBM Plex Mono,monospace';
    ctx.fillText(`z = ${re.toFixed(2)} + ${im.toFixed(2)}j  |  |z| = ${mod.toFixed(3)}  |  φ = ${phase.toFixed(1)}°`,10,H-10);
  }
  draw(1.5, 1.0);
  c.addEventListener('click', e=>{
    const r=c.getBoundingClientRect(), cx=c.width/2, cy=c.height/2, sc=70;
    draw((e.clientX-r.left-cx)/sc, -(e.clientY-r.top-cy)/sc);
  });
})();

// ═══ CONJUGATE CANVAS ═══
(function(){
  const c = document.getElementById('c_conj'); if(!c) return;
  function draw(re, im) {
    const {ctx,W,H} = clearC('c_conj')||{}; if(!ctx) return;
    const cx=W/2, cy=H/2, sc=75;
    drawAxes(ctx,W,H,cx,cy,sc,'Re','Im');
    // mirror line label
    ctx.fillStyle='rgba(136,136,119,0.5)'; ctx.font='10px IBM Plex Mono,monospace';
    ctx.fillText('real axis (mirror)',cx-55,cy-6);
    // z
    arrow(ctx,cx,cy,cx+re*sc,cy-im*sc,'#2c5282','z',2.5);
    ctx.beginPath(); ctx.arc(cx+re*sc,cy-im*sc,4,0,Math.PI*2);
    ctx.fillStyle='#2c5282'; ctx.fill();
    // z* (reflected)
    arrow(ctx,cx,cy,cx+re*sc,cy+im*sc,'#c0392b','z*',2.5);
    ctx.beginPath(); ctx.arc(cx+re*sc,cy+im*sc,4,0,Math.PI*2);
    ctx.fillStyle='#c0392b'; ctx.fill();
    // dashed vertical connecting z to z*
    ctx.strokeStyle='rgba(136,136,119,0.3)'; ctx.lineWidth=1; ctx.setLineDash([4,3]);
    ctx.beginPath(); ctx.moveTo(cx+re*sc,cy-im*sc); ctx.lineTo(cx+re*sc,cy+im*sc); ctx.stroke();
    ctx.setLineDash([]);
    const mod=Math.sqrt(re*re+im*im);
    ctx.fillStyle='#1a1a14'; ctx.font='11px IBM Plex Mono,monospace';
    ctx.fillText(`z = ${re.toFixed(2)} + ${im.toFixed(2)}j  →  z* = ${re.toFixed(2)} − ${im.toFixed(2)}j  |  |z|=|z*|=${mod.toFixed(3)}`,8,H-10);
  }
  draw(1.2, 1.0);
  c.addEventListener('click', e=>{
    const r=c.getBoundingClientRect(), cx=c.width/2, cy=c.height/2, sc=75;
    draw((e.clientX-r.left-cx)/sc, -(e.clientY-r.top-cy)/sc);
  });
})();

// ═══ NEW CHECKS ═══
function chkConj(fb) {
  const a = document.getElementById('ac31a').value.trim().replace(/\s/g,'').toLowerCase();
  const b = document.getElementById('ac31b').value.trim().replace(/\s/g,'').toLowerCase();
  const c = document.getElementById('ac31c').value.trim().replace(/\s/g,'').toLowerCase();
  const okA = a==='5-2j' || a==='5-2i';
  const okB = b==='-3+j' || b==='-3+1j' || b==='-3+i';
  const okC = c==='4';
  document.getElementById('ac31a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ac31b').className='answer-input '+(okB?'ok':'no');
  document.getElementById('ac31c').className='answer-input '+(okC?'ok':'no');
  const ok=okA&&okB&&okC;
  setFb(fb, ok, ok
    ? '✓ Perfect! a) 5−2j  b) −3+j  c) 4. Pure real numbers are their own conjugate!'
    : '✗ Remember: change ONLY the sign of j. a) 5+2j→5−2j  b) −3−j→−3+j  c) 4→4');
  }

function chkMod(fb) {
  const a = document.getElementById('ac32a').value.trim();
  const b = document.getElementById('ac32b').value.trim();
  const okA = isApprox(a, 25) || a==='25';
  const okB = isApprox(b, 1) || b==='1';
  document.getElementById('ac32a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ac32b').className='answer-input '+(okB?'ok':'no');
  const ok=okA&&okB;
  setFb(fb, ok, ok
    ? '✓ Great! a) 9+16=25  b) 1/2+1/2=1. Case b) is crucial: 1/√2 + j/√2 has squared modulus 1 → it is a valid quantum amplitude!'
    : '✗ a) 3²+4²=9+16=?  b) (1/√2)²+(1/√2)²=1/2+1/2=?');
  }

function chkZZstar(fb) {
  const a = document.getElementById('ac33a').value.trim();
  const b = document.getElementById('ac33b').value.trim();
  const okA = a==='-1' || isApprox(a,-1);
  const okB = isApprox(b,13) || b==='13';
  document.getElementById('ac33a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ac33b').className='answer-input '+(okB?'ok':'no');
  const ok=okA&&okB;
  setFb(fb, ok, ok
    ? '✓ Correct! j²=−1 (by definition!) → −9j²=+9 → 4+9=13. Check: 2²+3²=4+9=13 ✓ The z·z* trick always works!'
    : '✗ j² = −1 by definition. So −9·j² = −9·(−1) = +9. Then 4+9=?');
  }

function goTo(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
