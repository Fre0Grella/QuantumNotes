  <!-- trick -->
  <h3>Practical tricks to speed up calculations</h3>

  <div class="insight">
    <strong>Trick 1 — aI + bL has the same eigenvectors as L</strong><br>
    If M = aI + bL, then M|u⟩ = aI|u⟩ + bL|u⟩ = a|u⟩ + bλ|u⟩ = (a + bλ)|u⟩.<br>
    Eigenvectors are unchanged; eigenvalues become a + bλ.<br><br>
    <span style="color:var(--ink2)">Example: A = ((3,1),(1,3)) = 3I + X &nbsp;→&nbsp; same eigenvectors as X (i.e. |+⟩ and |−⟩), eigenvalues 3±1 = 4 and 2.</span>
  </div>

  <div class="insight">
    <strong>Trick 2 — Diagonal matrices: eigenvalues = diagonal elements</strong><br>
    If D = ((d₁, 0), (0, d₂)) then the eigenvalues are simply d₁ and d₂, and the eigenvectors are e₁=(1,0)ᵀ and e₂=(0,1)ᵀ. No calculation needed.<br><br>
    <span style="color:var(--ink2)">Example: Pauli Z = ((1,0),(0,−1)) &nbsp;→&nbsp; eigenvalues +1 and −1 at a glance, eigenvectors |0⟩ and |1⟩.</span>
  </div>

  <div class="insight">
    <strong>Trick 3 — Trace and determinant</strong><br>
    For a 2×2 matrix the characteristic equation is always λ² − tr(L)·λ + det(L) = 0, where:<br>
    tr(L) = sum of diagonal elements &nbsp;&nbsp; det(L) = ad − bc<br>
    So λ₁ + λ₂ = tr(L) and λ₁ · λ₂ = det(L). You can verify eigenvalues without redoing all the multiplications.<br><br>
    <span style="color:var(--ink2)">Example: Pauli X = ((0,1),(1,0)) &nbsp;→&nbsp; tr=0, det=−1 &nbsp;→&nbsp; λ₁+λ₂=0 and λ₁·λ₂=−1 &nbsp;→&nbsp; must be +1 and −1 ✓</span>
  </div>

  <div class="insight">
    <strong>Trick 4 — Unitary matrices: eigenvalues have modulus 1</strong><br>
    If U is unitary (UᴴU = I), all its eigenvalues satisfy |λ| = 1. In quantum this means eigenvalues always lie on the unit circle in the complex plane. For Pauli matrices (which are also Hermitian) they are real → so they are exactly ±1.<br><br>
    <span style="color:var(--ink2)">If you find an eigenvalue with |λ| ≠ 1 for a unitary matrix, you have made a calculation error.</span>
  </div>

  <div class="insight">
    <strong>Trick 5 — Eigenvectors of Hermitian matrices are orthogonal</strong><br>
    If L = Lᴴ (Hermitian) and λ₁ ≠ λ₂, then the corresponding eigenvectors satisfy ⟨u₁|u₂⟩ = 0. No need to verify this: it is guaranteed by construction.<br><br>
    <span style="color:var(--ink2)">Example: ⟨+|−⟩ = (1/√2)(1/√2) + (1/√2)(−1/√2) = 1/2 − 1/2 = 0 ✓ &nbsp; (X is Hermitian, λ₁≠λ₂ → orthogonal)</span>
  </div>

  <div class="insight">
    <strong>Trick 6 — Once you find one eigenvector, the other is orthogonal to it</strong><br>
    For a 2×2 Hermitian matrix, once the first eigenvector (a, b)ᵀ is found, the second is automatically (−b*, a*)ᵀ (normalized). So you only need to solve one of the two equations and get the other for free.<br><br>
    <span style="color:var(--ink2)">Example: found |+⟩ = (1/√2, 1/√2)ᵀ for X &nbsp;→&nbsp; the other is (−1/√2, 1/√2)ᵀ... which is |−⟩ up to a global phase (irrelevant in quantum).</span>
  </div>

</div>


<script is:inline>
function setFb(id, ok, msg) {
  const el = document.getElementById(id);
  el.className = 'feedback show ' + (ok ? 'ok' : 'no');
  el.textContent = msg;
}
function showHint(id) { document.getElementById(id).classList.toggle('show'); }

// ═══ CHECKS ═══
function normalize(s) { return s.trim().toLowerCase().replace(/\s/g,''); }
function isApprox(a, target, eps=0.05) {
  const n = parseFloat(a.replace(',','.'));
  return !isNaN(n) && Math.abs(n - target) < eps;
}

function chk(inputId, expected, fbId) {
  const v = normalize(document.getElementById(inputId).value);
  const ok = v === normalize(expected) || isApprox(v, parseFloat(expected));
  document.getElementById(inputId).className = 'answer-input ' + (ok ? 'ok' : 'no');
  setFb(fbId, ok, ok ? '✓ Correct!' : `✗ Not quite. Try again — the answer is ${expected}.`);
  }

function chk2(i1, e1, i2, e2, fb) {
  const v1 = normalize(document.getElementById(i1).value);
  const v2 = normalize(document.getElementById(i2).value);
  const ok1 = v1 === normalize(e1) || isApprox(v1, parseFloat(e1));
  const ok2 = v2 === normalize(e2) || isApprox(v2, parseFloat(e2));
  document.getElementById(i1).className = 'answer-input ' + (ok1 ? 'ok' : 'no');
  document.getElementById(i2).className = 'answer-input ' + (ok2 ? 'ok' : 'no');
  const ok = ok1 && ok2;
  setFb(fb, ok, ok ? '✓ Perfect!' : `✗ Check again. Expected: ${e1} and ${e2}.`);
  }

function chk2n(i1,e1,i2,e2,fb) { chk2(i1,e1,i2,e2,fb); }

function chkFrac(i1,n1,d1, i2,n2,d2, fb) {
  const v1 = normalize(document.getElementById(i1).value);
  const v2 = normalize(document.getElementById(i2).value);
  const ok1 = v1===`${n1}/${d1}` || isApprox(v1, n1/d1);
  const ok2 = v2===`${n2}/${d2}` || isApprox(v2, n2/d2);
  document.getElementById(i1).className = 'answer-input '+(ok1?'ok':'no');
  document.getElementById(i2).className = 'answer-input '+(ok2?'ok':'no');
  const ok = ok1 && ok2;
  setFb(fb, ok, ok ? `✓ Correct! û = (${n1}/${d1}, ${n2}/${d2})ᵀ. Check: (${n1}/${d1})² + (${n2}/${d2})² = ${n1*n1}/${d1*d1} + ${n2*n2}/${d2*d2} = 1 ✓` : `✗ Try again. Divide each component by the norm (${d1}).`);
  }

function chkOrtho(i1,e1,i2,fb) {
  const v1 = normalize(document.getElementById(i1).value);
  const v2 = normalize(document.getElementById(i2).value);
  const ok1 = v1 === e1 || isApprox(v1, 0);
  const ok2 = v2.includes('yes') || v2.includes('si') || v2==='yes';
  document.getElementById(i1).className = 'answer-input '+(ok1?'ok':'no');
  document.getElementById(i2).className = 'answer-input '+(ok2?'ok':'no');
  const ok = ok1 && ok2;
  setFb(fb, ok, ok ? '✓ Yes! a·b = 1·1 + 1·(−1) = 1−1 = 0 → orthogonal. These are exactly the Hadamard |+⟩ and |−⟩ vectors!' : '✗ Try again: (1)(1) + (1)(−1) = ?');
  }

function chkBra(fb) {
  const v1 = normalize(document.getElementById('a41a').value);
  const v2 = document.getElementById('a41b').value.trim();
  const ok1 = v1.includes('row');
  const ok2 = v2 === '-3' || isApprox(v2, -3);
  document.getElementById('a41a').className = 'answer-input '+(ok1?'ok':'no');
  document.getElementById('a41b').className = 'answer-input '+(ok2?'ok':'no');
  const ok = ok1 && ok2;
  setFb(fb, ok, ok ? '✓ Perfect! The bra ⟨ψ| is the row vector (2, −3). For real components, the conjugate changes nothing.' : '✗ The bra is a row vector (transposed). Real components remain unchanged.');
  }

function chk3(i1,e1,i2,e2,i3,e3,fb) {
  const v1 = normalize(document.getElementById(i1).value);
  const v2 = normalize(document.getElementById(i2).value);
  const v3 = normalize(document.getElementById(i3).value);
  const ok1 = isApprox(v1,parseFloat(e1))||v1===e1;
  const ok2 = isApprox(v2,parseFloat(e2))||v2===e2;
  const ok3 = isApprox(v3,parseFloat(e3))||v3===e3;
  [i1,i2,i3].forEach((id,k)=>{
    const ok=[ok1,ok2,ok3][k];
    document.getElementById(id).className='answer-input '+(ok?'ok':'no');
  });
  const ok = ok1&&ok2&&ok3;
  setFb(fb, ok, ok ? '✓ Orthonormal basis verified! ⟨0|0⟩=⟨1|1⟩=1 (normalized), ⟨0|1⟩=0 (orthogonal).' : '✗ Try again. Remember: row × column product.');
  }

function chkQubit(fb) {
  const a = normalize(document.getElementById('a61a').value);
  const b = normalize(document.getElementById('a61b').value);
  const c = normalize(document.getElementById('a61c').value);
  const d = normalize(document.getElementById('a61d').value);
  const okA = isApprox(a,1)||a==='1';
  const okB = b.includes('yes')||b.includes('si')||b==='yes';
  const okC = isApprox(c,0.5)||a==='1/2';
  const okD = d.includes('no');
  ['a61a','a61b','a61c','a61d'].forEach((id,k)=>{
    document.getElementById(id).className='answer-input '+([okA,okB,okC,okD][k]?'ok':'no');
  });
  const ok = okA&&okB&&okD;
  setFb(fb, ok, ok ? '✓ Correct! a) 1/4+3/4=1 → valid. b) 1/4+1/4=1/2≠1 → NOT valid. To make it valid you would need (1/√2, 1/√2).' : '✗ a) (1/2)²+(√3/2)²=1/4+3/4=1 → yes. b) (1/2)²+(1/2)²=1/4+1/4=1/2 → no!');
  }

function chkBeta(fb) {
  const v = normalize(document.getElementById('a62').value);
  const target = Math.sqrt(2/3);
  const ok = isApprox(v, target, 0.01) || v.includes('√(2/3)') || v.includes('sqrt(2/3)') || v==='√2/√3';
  document.getElementById('a62').className='answer-input '+(ok?'ok':'no');
  setFb(fb, ok, ok ? `✓ Correct! β = √(2/3) ≈ ${target.toFixed(4)}. Check: 1/3 + 2/3 = 1 ✓` : `✗ Try again. β² = 1 − 1/3 = 2/3 → β = √(2/3) ≈ ${target.toFixed(3)}`);
  }

function chkMeas(fb) {
  const a = normalize(document.getElementById('a71a').value);
  const b = normalize(document.getElementById('a71b').value);
  const c = normalize(document.getElementById('a71c').value);
  const okA = isApprox(a,0.75)||a==='3/4';
  const okB = isApprox(b,0.25)||b==='1/4';
  const okC = c.includes('0')||c.includes('|0');
  ['a71a','a71b','a71c'].forEach((id,k)=>{ document.getElementById(id).className='answer-input '+([okA,okB,okC][k]?'ok':'no'); });
  const ok=okA&&okB&&okC;
  setFb(fb, ok, ok ? '✓ Great! P(|0⟩)=(√3/2)²=3/4, P(|1⟩)=(1/2)²=1/4. |0⟩ is 3 times more likely.' : '✗ (√3/2)²=3/4, (1/2)²=1/4.');
  }

function chkQRNG(fb) {
  const a = normalize(document.getElementById('a72a').value);
  const b = normalize(document.getElementById('a72b').value);
  const c = normalize(document.getElementById('a72c').value);
  const d = normalize(document.getElementById('a72d').value);
  const ok1 = isApprox(a, 1/Math.SQRT2, 0.02) || a.includes('1/√2') || a.includes('1/sqrt');
  const ok2 = isApprox(b, 1/Math.SQRT2, 0.02) || b.includes('1/√2') || b.includes('1/sqrt');
  const ok3 = isApprox(c, 0.5, 0.02) || c==='1/2';
  const ok4 = isApprox(d, 0.5, 0.02) || d==='1/2';
  ['a72a','a72b','a72c','a72d'].forEach((id,k)=>{ document.getElementById(id).className='answer-input '+([ok1,ok2,ok3,ok4][k]?'ok':'no'); });
  const ok=ok1&&ok2&&ok3&&ok4;
  setFb(fb, ok, ok ? '✓ Perfect! α=β=1/√2, P(|0⟩)=P(|1⟩)=1/2. Every measurement is a perfect coin flip guaranteed by quantum physics!' : '✗ (|0⟩+|1⟩)/√2 means α=1/√2, β=1/√2.');
  }

function chkGateX(fb) {
  const a=document.getElementById('a81a').value.trim(), b=document.getElementById('a81b').value.trim(), c=normalize(document.getElementById('a81c').value);
  const okA=isApprox(a,1)||a==='1', okB=isApprox(b,0)||b==='0', okC=c.includes('0')||c==='|0>';
  ['a81a','a81b','a81c'].forEach((id,k)=>{ document.getElementById(id).className='answer-input '+([okA,okB,okC][k]?'ok':'no'); });
  const ok=okA&&okB&&okC;
  setFb(fb, ok, ok ? '✓ Correct! X|1⟩ = (0·0+1·1, 1·0+0·1)ᵀ = (1,0)ᵀ = |0⟩. The quantum NOT works!' : '✗ First row: 0·0+1·1=1. Second row: 1·0+0·1=0.');
  }

function chkHadamard(fb) {
  const a=normalize(document.getElementById('a82a').value), b=normalize(document.getElementById('a82b').value);
  const okA=isApprox(a,1/Math.SQRT2,0.01)||a.includes('1/√2')||a.includes('1/sqrt');
  const okB=isApprox(b,1/Math.SQRT2,0.01)||b.includes('1/√2')||b.includes('1/sqrt');
  ['a82a','a82b'].forEach((id,k)=>{ document.getElementById(id).className='answer-input '+([okA,okB][k]?'ok':'no'); });
  const ok=okA&&okB;
  setFb(fb, ok, ok ? `✓ Excellent! H|0⟩ = (1/√2)|0⟩ + (1/√2)|1⟩ = |+⟩. This is the uniform superposition state — the foundation of many quantum algorithms!` : '✗ 1/√2 ≈ 0.707. Both components must be 1/√2.');
  }

// ═══ CANVAS UTILITIES ═══
function clearC(id) {
  const c=document.getElementById(id); if(!c)return null;
  const ctx=c.getContext('2d'); ctx.clearRect(0,0,c.width,c.height); return {ctx,W:c.width,H:c.height};
}
function drawAxes(ctx,W,H,cx,cy,scale,lx,ly) {
  // grid
  ctx.strokeStyle='rgba(232,228,216,0.8)'; ctx.lineWidth=1;
  for(let x=cx%scale;x<W;x+=scale){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=cy%scale;y<H;y+=scale){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  // axes
  ctx.strokeStyle='rgba(136,136,119,0.6)'; ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(0,cy);ctx.lineTo(W,cy);ctx.stroke();
  ctx.beginPath();ctx.moveTo(cx,0);ctx.lineTo(cx,H);ctx.stroke();
  // labels
  ctx.fillStyle='#888877'; ctx.font='11px IBM Plex Mono, monospace';
  if(lx) ctx.fillText(lx, cx+scale+3, cy-5);
  if(ly) ctx.fillText(ly, cx+5, cy-scale-4);
}
function arrow(ctx,x1,y1,x2,y2,col,lbl,lw=2) {
  ctx.strokeStyle=col; ctx.fillStyle=col; ctx.lineWidth=lw;
  ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
  const a=Math.atan2(y2-y1,x2-x1),s=8;
  ctx.beginPath();ctx.moveTo(x2,y2);
  ctx.lineTo(x2-s*Math.cos(a-0.4),y2-s*Math.sin(a-0.4));
  ctx.lineTo(x2-s*Math.cos(a+0.4),y2-s*Math.sin(a+0.4));
  ctx.closePath();ctx.fill();
  if(lbl){ctx.font='bold 12px IBM Plex Mono,monospace';ctx.fillStyle=col;ctx.fillText(lbl,x2+7,y2-5);}
}

