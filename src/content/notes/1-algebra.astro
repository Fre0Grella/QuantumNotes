  document.getElementById('ae12b').className='answer-input '+(okB?'ok':'no');
  document.getElementById('ae12c').className='answer-input '+(okC?'ok':'no');
  const ok=okA&&okB&&okC;
  setFb(fb, ok,
    ok ? '✓ Great! √4=2, λ₁=(6+2)/2=4, λ₂=(6−2)/2=2. Or: λ²−6λ+8=(λ−4)(λ−2)=0.'
       : '✗ √(36−32)=√4=2. Then (6+2)/2=4 and (6−2)/2=2.');
  }

function chkEigVec(fb) {
  const a = document.getElementById('ae13a').value.trim().replace(/\s/g,'');
  const b = document.getElementById('ae13b').value.trim().replace(/\s/g,'');
  const v = 1/Math.SQRT2;
  const okA = isApprox(a, v, 0.01) || a==='1/√2' || a==='1/sqrt(2)' || a==='√2/2';
  const okB = isApprox(b, v, 0.01) || b==='1/√2' || b==='1/sqrt(2)' || b==='√2/2';
  document.getElementById('ae13a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ae13b').className='answer-input '+(okB?'ok':'no');
  const ok=okA&&okB;
  setFb(fb, ok,
    ok ? '✓ Perfect! |u₁⟩ = (1/√2, 1/√2)ᵀ ≈ (0.707, 0.707)ᵀ. Fun fact: it is identical to |+⟩ = H|0⟩!'
       : '✗ u₁=1, u₂=1 → norm=√2 → divide: (1/√2, 1/√2)ᵀ ≈ (0.707, 0.707)ᵀ');
