function updateDot(){
  const th=parseFloat(document.getElementById('dotSlider').value);
  document.getElementById('dotVal').textContent=th+'°';
  const {ctx,W,H}=clearC('c_dot')||{}; if(!ctx)return;
  const cx=W/2,cy=H/2,sc=90;
  drawAxes(ctx,W,H,cx,cy,sc);
  const r=th*Math.PI/180;
  const u=[1,0], v=[Math.cos(r),Math.sin(r)];
  const dot=u[0]*v[0]+u[1]*v[1];
  // angle arc
  ctx.strokeStyle='rgba(183,83,10,0.35)';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.arc(cx,cy,30,0,-r,r>0);ctx.stroke();
  ctx.fillStyle='rgba(183,83,10,0.7)';ctx.font='10px IBM Plex Mono,monospace';
  ctx.fillText(`θ=${th}°`,cx+34,cy-8);
  // projection of v onto u
  const projLen=dot*sc;
  ctx.strokeStyle='rgba(136,136,119,0.3)';ctx.lineWidth=1;ctx.setLineDash([3,3]);
  ctx.beginPath();ctx.moveTo(cx+v[0]*sc,cy-v[1]*sc);ctx.lineTo(cx+projLen,cy);ctx.stroke();
  ctx.setLineDash([]);
  // dot product bar
  const barY=H-18;
  ctx.fillStyle='rgba(44,82,130,0.15)';
  ctx.fillRect(cx,barY-6,projLen,12);
  ctx.strokeStyle='#2c5282';ctx.lineWidth=1.5;
  ctx.strokeRect(cx,barY-6,projLen,12);
  arrow(ctx,cx,cy,cx+u[0]*sc,cy-u[1]*sc,'#c0392b','u');
  arrow(ctx,cx,cy,cx+v[0]*sc,cy-v[1]*sc,'#2c5282','v');
  document.getElementById('dotLive').textContent=`u·v = cos(${th}°) = ${dot.toFixed(4)}  |  ${th===90?'⊥ Orthogonal!':th===0?'Parallel (max)':th===180?'Antiparallel (min)':''}`;
}
updateDot();

