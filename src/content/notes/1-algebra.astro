    ctx.beginPath();ctx.moveTo(cx+vx*sc,cy-vy*sc);ctx.lineTo(cx,cy-vy*sc);ctx.stroke();
    ctx.setLineDash([]);
    // component labels
    ctx.fillStyle='rgba(192,57,43,0.7)';ctx.font='11px IBM Plex Mono,monospace';
