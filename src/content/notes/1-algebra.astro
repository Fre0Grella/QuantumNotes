let measCnts=[0,0];
function updateMeas(){
  const th=parseFloat(document.getElementById('measSlider').value);
  document.getElementById('measVal').textContent=th+'°';
  const a=Math.cos(th*Math.PI/180),b=Math.sin(th*Math.PI/180);
  document.getElementById('measLive').textContent=`|ψ⟩ = ${a.toFixed(3)}|0⟩ + ${b.toFixed(3)}|1⟩  →  P(|0⟩)=${(a*a).toFixed(3)}, P(|1⟩)=${(b*b).toFixed(3)}`;
  drawMeas();
}
function doMeasure(n){
  const th=parseFloat(document.getElementById('measSlider').value);
  const p0=Math.cos(th*Math.PI/180)**2;
  for(let i=0;i<n;i++){ if(Math.random()<p0)measCnts[0]++;else measCnts[1]++; }
  drawMeas();
  const tot=measCnts[0]+measCnts[1];
  document.getElementById('measStats').textContent=`Total: ${tot}  |  |0⟩: ${measCnts[0]} (${(measCnts[0]/tot*100).toFixed(1)}%)  |  |1⟩: ${measCnts[1]} (${(measCnts[1]/tot*100).toFixed(1)}%)`;
}
function resetMeasure(){ measCnts=[0,0]; drawMeas(); document.getElementById('measStats').textContent=''; }
function drawMeas(){
  const {ctx,W,H}=clearC('c_meas')||{}; if(!ctx)return;
  ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const th=parseFloat(document.getElementById('measSlider').value);
  const p0=Math.cos(th*Math.PI/180)**2,p1=1-p0;
  const tot=measCnts[0]+measCnts[1];
  const bW=80,pad=80;
  [[p0,tot?measCnts[0]/tot:0,'|0⟩','#2c5282','#1a6b3a'],
   [p1,tot?measCnts[1]/tot:0,'|1⟩','#c0392b','#b7530a']].forEach(([pt,pe,lbl,ct,ce],i)=>{
    const x=pad+i*(bW*2+60);
    const bh=pt*(H-50);
    ctx.fillStyle=ct+'22';ctx.fillRect(x,H-35-bh,bW,bh);
    ctx.strokeStyle=ct;ctx.lineWidth=1.5;ctx.strokeRect(x,H-35-bh,bW,bh);
    ctx.fillStyle=ct;ctx.font='10px IBM Plex Mono,monospace';
    ctx.fillText('theoretical',x+10,H-18);ctx.fillText((pt*100).toFixed(0)+'%',x+25,H-37-bh);
    const bh2=pe*(H-50);
    const x2=x+bW+5;
    ctx.fillStyle=ce+'22';ctx.fillRect(x2,H-35-bh2,bW,bh2);
    ctx.strokeStyle=ce;ctx.lineWidth=1.5;ctx.strokeRect(x2,H-35-bh2,bW,bh2);
    ctx.fillStyle=ce;ctx.font='10px IBM Plex Mono,monospace';
    ctx.fillText('empirical',x2+8,H-18);
    if(tot>0)ctx.fillText((pe*100).toFixed(0)+'%',x2+25,H-37-bh2-2);
    ctx.fillStyle='#1a1a14';ctx.font='bold 14px IBM Plex Mono,monospace';
    ctx.fillText(lbl,x+bW/2-10,25);
  });
}
updateMeas();

