// ═══ EIGENVALUE EXERCISE CHECKS ═══
function chkMinusLambda(fb) {
  const a = document.getElementById('ae11a').value.trim().replace(/\s/g,'');
  const b = document.getElementById('ae11b').value.trim().replace(/\s/g,'');
  const okA = a==='3-λ' || a==='3−λ' || a==='-λ+3' || a==='3-lambda';
  const okB = b==='3-λ' || b==='3−λ' || b==='-λ+3' || b==='3-lambda';
  document.getElementById('ae11a').className='answer-input '+(okA?'ok':'no');
  document.getElementById('ae11b').className='answer-input '+(okB?'ok':'no');
  const ok=okA&&okB;
  setFb(fb, ok,
    ok ? '✓ Correct! A − λI = ((3−λ, 1),(1, 3−λ)). Off-diagonal elements are unchanged; λ is subtracted only from (1,1) and (2,2).'
       : '✗ Subtract λ only from the diagonal: element (1,1) → 3−λ, element (2,2) → 3−λ. Elements 1 and 1 remain unchanged.');
  }

function chkEigA(fb) {
  const a = document.getElementById('ae12a').value.trim();
  const b = document.getElementById('ae12b').value.trim();
  const c = document.getElementById('ae12c').value.trim();
  const okA = isApprox(a,2)||a==='2';
  const okB = isApprox(b,4)||b==='4';
