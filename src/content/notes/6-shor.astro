  <text x="58" y="109" font-size="12" fill="#2c5282" text-anchor="end">|0⟩</text>

  <!-- H gates reg 1 -->
  <rect x="160" y="56" width="28" height="24" rx="3" fill="white" stroke="#2c5282" stroke-width="2"/>
  <text x="174" y="73" font-size="13" font-weight="bold" fill="#2c5282" text-anchor="middle">H</text>
