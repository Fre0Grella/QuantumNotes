  <button class="btn sm" onclick="drawQFTPeaks()">Show QFT</button>
</div>
<div id="qftPeakInfo" style="font-family:'IBM Plex Mono',monospace;font-size:0.78rem;color:var(--ink2);margin-top:0.4rem;min-height:1.2rem;"></div>

<!-- Exercises -->
<div class="ex-block">
