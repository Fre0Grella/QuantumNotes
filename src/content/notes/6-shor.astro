<script is:inline>
/* ── Helpers ───────────────────────────────────────────────────── */
function goTo(id){const el=document.getElementById(id);if(el)el.scrollIntoView({behavior:'smooth',block:'start'});}
function showHint(id){document.getElementById(id).classList.toggle('show');}
function setFb(id,ok,msg){const el=document.getElementById(id);if(!el)return;el.className='feedback show '+(ok?'ok':'no');el.textContent=msg;}
function norm(s){return s.trim().toLowerCase().replace(/\s/g,'').replace('−','-').replace('√','√');}
function chk(iid,exp,fb){const v=norm(document.getElementById(iid).value);const ok=v===norm(exp)||(!isNaN(v)&&!isNaN(exp)&&Math.abs(parseFloat(v)-parseFloat(exp))<0.01);document.getElementById(iid).className='answer-input '+(ok?'ok':'no');setFb(fb,ok,ok?'✓ Correct!':'✗ Not quite — try again or show hint.');}
function chk2(i1,i2,e1,e2,fb){const ok1=norm(document.getElementById(i1).value)===norm(e1)||(!isNaN(document.getElementById(i1).value)&&Math.abs(parseFloat(document.getElementById(i1).value)-parseFloat(e1))<0.01);const ok2=norm(document.getElementById(i2).value)===norm(e2)||(!isNaN(document.getElementById(i2).value)&&Math.abs(parseFloat(document.getElementById(i2).value)-parseFloat(e2))<0.01);document.getElementById(i1).className='answer-input '+(ok1?'ok':'no');document.getElementById(i2).className='answer-input '+(ok2?'ok':'no');setFb(fb,ok1&&ok2,ok1&&ok2?'✓ Both correct!':'✗ Not quite.');}
function chkContains(iid,kws,fb){const v=document.getElementById(iid).value.toLowerCase();const ok=kws.some(k=>v.includes(k));document.getElementById(iid).className='answer-input '+(ok?'ok':'no');setFb(fb,ok,ok?'✓ Correct!':'✗ Not quite — check the hint.');}

/* ── GCD (Euclidean) ────────────────────────────────────────────── */
function gcd(a,b){a=Math.abs(a);b=Math.abs(b);while(b){let t=b;b=a%b;a=t;}return a;}
function modpow(base,exp,mod){let result=1;base=base%mod;while(exp>0){if(exp%2===1)result=(result*base)%mod;exp=Math.floor(exp/2);base=(base*base)%mod;}return result;}
function findOrder(x,n){for(let r=1;r<=n;r++){if(modpow(x,r,n)===1)return r;}return null;}

/* ── Deutsch Simulator ─────────────────────────────────────────── */
const fDefs={c0:[0,0],c1:[1,1],id:[0,1],not:[1,0]};
function runDeutsch(type){
  const cv=document.getElementById('cvDeutsch');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const [f0,f1]=fDefs[type];
  const isConst=f0===f1;
  const accent='#2c5282',red='#c0392b',green='#1a6b3a',muted='#888877';
  // labels
  const stages=['|0⟩','after H','after U_f','after H','measure'];
  const xPos=[45,150,280,380,490];
  stages.forEach((s,i)=>{ctx.fillStyle=muted;ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText(s,xPos[i],14);});
  // wires
  ctx.strokeStyle='#dedad0';ctx.lineWidth=1.5;
  [70,130].forEach(y=>{ctx.beginPath();ctx.moveTo(20,y);ctx.lineTo(W-20,y);ctx.stroke();});
  // gate boxes
  const drawGate=(x,y,label,col)=>{ctx.fillStyle='white';ctx.strokeStyle=col;ctx.lineWidth=2;ctx.beginPath();ctx.roundRect(x-18,y-18,36,36,3);ctx.fill();ctx.stroke();ctx.fillStyle=col;ctx.font="bold 14px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(label,x,y);};
  drawGate(110,70,'H',accent);drawGate(110,130,'H',accent);
  const uf_x=255;ctx.fillStyle='#f0e8ff';ctx.strokeStyle='#6b21a8';ctx.lineWidth=2;ctx.beginPath();ctx.roundRect(uf_x-30,50,60,100,4);ctx.fill();ctx.stroke();ctx.fillStyle='#6b21a8';ctx.font="bold 14px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('U_f',uf_x,100);
  drawGate(375,70,'H',accent);
  // state labels
  const stateLabel=(x,y,text,col)=>{ctx.fillStyle=col;ctx.font="11px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(text,x,y);};
  stateLabel(45,70,'|0⟩',accent);stateLabel(45,130,'|1⟩',accent);
  stateLabel(175,70,'|+⟩',accent);stateLabel(175,130,'|−⟩',accent);
  const reg1after=isConst?'±|+⟩':'±|−⟩';
  stateLabel(325,70,reg1after,isConst?green:red);stateLabel(325,130,'|−⟩',muted);
  stateLabel(430,70,isConst?'±|+⟩':'±|−⟩',isConst?green:red);
  // measurement result
  const mBox_x=480,mBox_y=70;
  ctx.fillStyle=isConst?green:red;ctx.beginPath();ctx.roundRect(mBox_x-22,mBox_y-18,44,36,4);ctx.fill();
  ctx.fillStyle='white';ctx.font="bold 16px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(isConst?'"0"':'"1"',mBox_x,mBox_y);
  // info text
  ctx.fillStyle=isConst?green:red;ctx.font="12px 'IBM Plex Sans',sans-serif";ctx.textAlign='center';ctx.textBaseline='top';
  ctx.fillText(`f(0)=${f0}, f(1)=${f1} → ${isConst?'Constant: measure 0':'Balanced: measure 1'}`,W/2,165);
  const el=document.getElementById('deutschResult');if(el)el.textContent=`f(0)=${f0}, f(1)=${f1} → f is ${isConst?'CONSTANT':'BALANCED'} → measure "${isConst?0:1}" on first register`;el.style.color=isConst?green:red;
  // activate button
  ['c0','c1','id','not'].forEach(k=>{const b=document.getElementById('df'+['c0','c1','id','not'].indexOf(k));if(b)b.classList.remove('active');});
}
runDeutsch('c0');

/* ── Factoring tracer ──────────────────────────────────────────── */
function runFactor(){
  const n=parseInt(document.getElementById('fnN').value);
  const x=parseInt(document.getElementById('fnX').value);
  const cv=document.getElementById('cvFactor');
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const lines=[];
  if(isNaN(n)||isNaN(x)||n<2||x<1){lines.push('Invalid input.');return;}
  const g=gcd(x,n);
  if(g>1){lines.push(`① gcd(${x},${n}) = ${g} > 1 → ${g} is already a factor! (Lucky stop)`);renderLines(ctx,lines,W,H);return;}
  lines.push(`① gcd(${x},${n}) = 1 ✓ — continue`);
  const r=findOrder(x,n);
  if(!r){lines.push(`② Could not find order for x=${x}, n=${n}`);renderLines(ctx,lines,W,H);return;}
  lines.push(`② Order r = ${r} &nbsp; (${x}^${r} mod ${n} = ${modpow(x,r,n)} = 1)`);
  if(r%2!==0){lines.push(`③ r = ${r} is odd → restart (go to step ①)`);renderLines(ctx,lines,W,H);return;}
  const xhalf=modpow(x,r/2,n);
  if((xhalf+1)%n===0){lines.push(`③ (x^(r/2)+1) mod n = ${(xhalf+1)%n} = 0 → restart`);renderLines(ctx,lines,W,H);return;}
  lines.push(`③ r = ${r} is even ✓ &nbsp; x^(r/2) = ${x}^${r/2} mod ${n} = ${xhalf}`);
  const f1=gcd(xhalf-1,n);
  const f2=gcd(xhalf+1,n);
  lines.push(`④ gcd(${xhalf}-1, ${n}) = gcd(${xhalf-1}, ${n}) = ${f1}`);
  lines.push(`   gcd(${xhalf}+1, ${n}) = gcd(${xhalf+1}, ${n}) = ${f2}`);
  if(f1!==1&&f1!==n)lines.push(`✓ Non-trivial factor: ${f1}`);
  if(f2!==1&&f2!==n)lines.push(`✓ Non-trivial factor: ${f2}`);
  if((f1===1||f1===n)&&(f2===1||f2===n))lines.push('⚠ No non-trivial factor found — choose different x');
  renderLines(ctx,lines,W,H);
  const el=document.getElementById('factorResult');if(el)el.textContent=lines.join('\n');
}
function renderLines(ctx,lines,W,H){
  ctx.fillStyle='#1a1a14';ctx.font="11.5px 'IBM Plex Mono',monospace";ctx.textBaseline='top';
  lines.forEach((l,i)=>ctx.fillText(l,10,10+i*22));
}
runFactor();

/* ── Period canvas ─────────────────────────────────────────────── */
function drawPeriodCanvas(){
  const n=parseInt(document.getElementById('pN').value)||15;
  const x=parseInt(document.getElementById('pX').value)||7;
  const cv=document.getElementById('cvPeriod');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const L=Math.min(4*n,64);
  const seq=[];for(let i=0;i<L;i++)seq.push(modpow(x,i,n));
  const bw=Math.max(4,Math.floor((W-40)/(L)));
  const maxVal=Math.max(...seq,1);
  const r=findOrder(x,n);
  // grid
  ctx.strokeStyle='#f0ede6';ctx.lineWidth=1;
  for(let v=0;v<=maxVal;v+=Math.ceil(maxVal/5)){const y=H-30-(v/maxVal)*(H-50);ctx.beginPath();ctx.moveTo(30,y);ctx.lineTo(W-10,y);ctx.stroke();ctx.fillStyle='#bbb';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='right';ctx.fillText(v,27,y+3);}
  // bars
  seq.forEach((v,i)=>{
    const hue=r?((i%r)/r*120):200;
    const col=`hsl(${hue+180},55%,45%)`;
    const bh=(v/maxVal)*(H-50);
    const bx=30+i*bw;
    const by=H-30-bh;
    ctx.fillStyle=col;ctx.fillRect(bx,by,bw-1,bh);
    if(bw>12&&i<30){ctx.fillStyle='#555';ctx.font="8px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText(i,bx+bw/2,H-15);}
  });
  // period marker
  if(r){ctx.strokeStyle='#c0392b';ctx.lineWidth=2;ctx.setLineDash([4,3]);ctx.beginPath();ctx.moveTo(30+r*bw,5);ctx.lineTo(30+r*bw,H-30);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#c0392b';ctx.font="bold 10px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText('r='+r,30+r*bw+3,12);}
  ctx.fillStyle='#888';ctx.font="10px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText(`f(ℓ) = ${x}^ℓ mod ${n}  (period r=${r||'?'})`,35,H-2);
}
drawPeriodCanvas();

/* ── DFT canvas ────────────────────────────────────────────────── */
function computeDFT(seq,N){
  const n=seq.length;
  const Re=new Array(N).fill(0),Im=new Array(N).fill(0);
  for(let k=0;k<N;k++){for(let j=0;j<n;j++){const ang=-2*Math.PI*k*j/N;Re[k]+=seq[j]*Math.cos(ang);Im[k]+=seq[j]*Math.sin(ang);}}
  return Re.map((r,i)=>Math.sqrt(r*r+Im[i]*Im[i])/N);
}
function drawDFTCanvas(){
  const n=parseInt(document.getElementById('dN').value)||15;
  const x=parseInt(document.getElementById('dX').value)||7;
  const N=Math.min(parseInt(document.getElementById('dNFT').value)||64,256);
  const cv=document.getElementById('cvDFT');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const seq=[];for(let i=0;i<N;i++)seq.push(modpow(x,i,n));
  const mag=computeDFT(seq,N);
  const maxMag=Math.max(...mag,0.01);
  const r=findOrder(x,n);
  const bw=Math.max(1,Math.floor((W-40)/N));
  mag.forEach((v,i)=>{const h=(v/maxMag)*(H-50);const bx=30+i*bw;ctx.fillStyle='#3b6ca8aa';ctx.fillRect(bx,H-35-h,bw,h);});
  // theoretical peak positions
  if(r){ctx.strokeStyle='#c0392b';ctx.lineWidth=1.5;ctx.setLineDash([3,3]);
    for(let l=0;l*N/r<N;l++){const px=30+Math.round(l*N/r)*bw;ctx.beginPath();ctx.moveTo(px,5);ctx.lineTo(px,H-35);ctx.stroke();}
    ctx.setLineDash([]);}
  ctx.strokeStyle='#ccc';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(30,H-35);ctx.lineTo(W-10,H-35);ctx.stroke();
  ctx.fillStyle='#888';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText(`DFT of ${x}^ℓ mod ${n}, N=${N}, r=${r||'?'}  (red lines = peaks at ℓ·N/r)`,30,H-3);
  const el=document.getElementById('dftInfo');if(el)el.textContent=`Period r=${r}, N=${N}, ideal peaks at m = 0, ${r?Math.round(N/r):'?'}, ${r?Math.round(2*N/r):'?'}, ... (multiples of N/r = ${r?Math.round(N/r):'?'})`;
}
drawDFTCanvas();

/* ── QFT peaks canvas ──────────────────────────────────────────── */
function drawQFTPeaks(){
  const x=parseInt(document.getElementById('qN2').value)||7;
  const n=parseInt(document.getElementById('qN3').value)||15;
  const N=Math.min(parseInt(document.getElementById('qN4').value)||1024,2048);
  const cv=document.getElementById('cvQFTPeaks');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const r=findOrder(x,n);if(!r){ctx.fillStyle='#c0392b';ctx.font="12px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText('gcd(x,n)≠1 or order not found',W/2,H/2);return;}
  // compute unnormalized |X_q|^2 for displaying
  // X_q for periodic state |a⟩+|a+r⟩+... summed over M terms
  const a=0,M=Math.floor(N/r);
  const probs=new Array(N).fill(0);
  for(let q=0;q<N;q++){
    let re=0,im=0;
    for(let d=0;d<M;d++){const ang=2*Math.PI*(a+d*r)*q/N;re+=Math.cos(ang);im+=Math.sin(ang);}
    probs[q]=(re*re+im*im)/(N*M);
  }
  const maxP=Math.max(...probs,1e-9);
  const step=Math.max(1,Math.floor(N/W));
  // bars
  ctx.fillStyle='#3b6ca888';
  for(let q=0;q<N;q+=step){const h=(probs[q]/maxP)*(H-50);ctx.fillRect(30+q*(W-40)/N,H-35-h,Math.max(1,(W-40)/N*step),h);}
  // theoretical peak markers
  ctx.strokeStyle='#c0392b';ctx.lineWidth=1.5;ctx.setLineDash([4,3]);
  for(let l=0;l<r;l++){const qp=Math.round(l*N/r);const px=30+qp*(W-40)/N;ctx.beginPath();ctx.moveTo(px,5);ctx.lineTo(px,H-35);ctx.stroke();}
  ctx.setLineDash([]);
  ctx.strokeStyle='#ccc';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(30,H-35);ctx.lineTo(W-10,H-35);ctx.stroke();
  ctx.fillStyle='#888';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText(`QFT: x=${x}, n=${n}, N=${N}, r=${r}   peaks at ℓ·${Math.round(N/r)}`,30,H-3);
  const el=document.getElementById('qftPeakInfo');if(el)el.textContent=`Order r=${r}. Peaks at m = ${Array.from({length:r},(_,l)=>l*Math.round(N/r)).join(', ')}. Each prob ≈ 1/r = ${(100/r).toFixed(1)}%`;
}
drawQFTPeaks();

/* ── Complexity canvas ─────────────────────────────────────────── */
function drawComplexity(){
  const b=parseInt(document.getElementById('slB').value);
  document.getElementById('bVal').textContent=b;
  const cv=document.getElementById('cvComplexity');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);
  const PL=50,PR=20,PT=20,PB=40,pW=W-PL-PR,pH=H-PT-PB;
  const maxb=40;
  // axes
  ctx.strokeStyle='#ccc';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(PL,PT);ctx.lineTo(PL,PT+pH);ctx.lineTo(PL+pW,PT+pH);ctx.stroke();
  ctx.fillStyle='#888';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText('b (bits)',PL+pW/2,H-3);
  // curves
  const maxShor=Math.pow(maxb,3);
  const maxClass=Math.pow(2,maxb);
  // Shor O(b³)
  ctx.strokeStyle='#1a6b3a';ctx.lineWidth=2;ctx.beginPath();
  for(let bi=1;bi<=maxb;bi++){const px=PL+(bi-1)/(maxb-1)*pW;const py=PT+pH-Math.min(Math.pow(bi,3)/maxShor,1)*pH;if(bi===1)ctx.moveTo(px,py);else ctx.lineTo(px,py);}
  ctx.stroke();
  // Classical O(2^b) — clamped
  ctx.strokeStyle='#c0392b';ctx.lineWidth=2;ctx.beginPath();let moved=false;
  for(let bi=1;bi<=maxb;bi++){const px=PL+(bi-1)/(maxb-1)*pW;const v=Math.pow(2,bi)/maxClass;if(v>1)break;const py=PT+pH-v*pH;if(!moved){ctx.moveTo(px,py);moved=true;}else ctx.lineTo(px,py);}
  ctx.stroke();
  // current b marker
  const curPx=PL+(b-1)/(maxb-1)*pW;
  ctx.strokeStyle='#2c5282';ctx.lineWidth=1;ctx.setLineDash([3,3]);ctx.beginPath();ctx.moveTo(curPx,PT);ctx.lineTo(curPx,PT+pH);ctx.stroke();ctx.setLineDash([]);
  ctx.fillStyle='#2c5282';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText('b='+b,curPx,PT-5);
  // labels
  ctx.fillStyle='#1a6b3a';ctx.fillText('Shor O(b³)',PL+pW*0.25,PT+pH*0.08);
  ctx.fillStyle='#c0392b';ctx.fillText('Classical O(2^b)',PL+pW*0.15,PT+pH*0.5);
  // values at current b
  const shorOps=Math.pow(b,3);
  const classOps=Math.pow(2,b);
  ctx.fillStyle='#555';ctx.font="10px 'IBM Plex Mono',monospace";ctx.textAlign='left';
  ctx.fillText(`b=${b}: Shor~${shorOps.toLocaleString()} ops, Classical~2^${b}=${classOps.toLocaleString()} ops`,PL+5,PT+pH+25);
}
drawComplexity();

/* ── Shor full simulator ────────────────────────────────────────── */
function runShortSim(){
  const n=parseInt(document.getElementById('sn').value)||15;
  const x=parseInt(document.getElementById('sx').value)||7;
  const N=Math.min(n*n*4,4096);
  let log='';
  const cv=document.getElementById('cvShor');if(!cv)return;
  cv.width=cv.parentElement.clientWidth-2;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fafaf8';ctx.fillRect(0,0,W,H);

  log+=`n=${n}, x=${x}, N=${N}\n`;
  const g=gcd(x,n);
  if(g>1){log+=`gcd(${x},${n})=${g}>1 — ${g} is a factor (lucky)!`;document.getElementById('shorLog').textContent=log;ctx.fillStyle='#1a6b3a';ctx.font="12px 'IBM Plex Mono',monospace";ctx.textAlign='center';ctx.fillText(`Factor found immediately: ${g}`,W/2,H/2);return;}

  const r=findOrder(x,n);
  if(!r){log+=`Could not find order.`;document.getElementById('shorLog').textContent=log;return;}
  log+=`Order r=${r} (${x}^${r} mod ${n} = ${modpow(x,r,n)})\n`;

  // Show periodic function
  const M=Math.floor(N/r);
  const seq=[];for(let i=0;i<Math.min(N,64);i++)seq.push(modpow(x,i,n));
  const maxVal=Math.max(...seq,1);
  const halfH=H/2-10;
  // panel 1: f(ℓ)
  const bw=Math.max(2,Math.floor((W/2-20)/seq.length));
  seq.forEach((v,i)=>{const hue=(i%r)/r*120+180;const h=(v/maxVal)*halfH*0.8;const bx=10+i*bw;ctx.fillStyle=`hsl(${hue},55%,45%)`;ctx.fillRect(bx,halfH-h,bw-1,h);});
  ctx.fillStyle='#888';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText(`f(ℓ)=${x}^ℓ mod ${n} (period=${r})`,8,halfH+12);

  // QFT peaks
  const probs=new Array(Math.min(N,512)).fill(0);
  const NQ=probs.length;
  for(let q=0;q<NQ;q++){let re=0,im=0;for(let d=0;d<M;d++){const ang=2*Math.PI*(d*r)*q/N;re+=Math.cos(ang);im+=Math.sin(ang);}probs[q]=(re*re+im*im)/(NQ*M);}
  const maxP=Math.max(...probs,1e-9);
  const pw=Math.max(1,Math.floor((W/2-20)/NQ));
  probs.forEach((v,i)=>{const h=(v/maxP)*halfH*0.8;const bx=W/2+10+i*pw;ctx.fillStyle='#2c5282aa';ctx.fillRect(bx,H-30-h,pw,h);});
  for(let l=0;l<r;l++){const qp=Math.round(l*NQ/r);ctx.strokeStyle='#c0392b';ctx.lineWidth=1;ctx.setLineDash([3,3]);ctx.beginPath();ctx.moveTo(W/2+10+qp*pw,H-100);ctx.lineTo(W/2+10+qp*pw,H-30);ctx.stroke();}
  ctx.setLineDash([]);
  ctx.fillStyle='#888';ctx.font="9px 'IBM Plex Mono',monospace";ctx.textAlign='left';ctx.fillText(`QFT output (${r} peaks)`,W/2+12,H-12);

  // Compute factors
  if(r%2===0){
    const xhalf=modpow(x,r/2,n);
    const f1=gcd(xhalf-1,n),f2=gcd(xhalf+1,n);
    log+=`r=${r} is even ✓, x^(r/2)=${xhalf}\n`;
    log+=`gcd(${xhalf-1},${n})=${f1}, gcd(${xhalf+1},${n})=${f2}\n`;
    const factors=[];
    if(f1!==1&&f1!==n)factors.push(f1);
    if(f2!==1&&f2!==n)factors.push(f2);
    if(factors.length)log+=`✓ Factors of ${n}: ${factors.join(' and ')}`;
    else log+=`⚠ No non-trivial factor found with this x. Try a different x.`;
  } else {
    log+=`r=${r} is odd → would need to restart. For this demo, r is odd.`;
  }
  document.getElementById('shorLog').textContent=log;
}
runShortSim();

/* ── init all on load ───────────────────────────────────────────── */
window.addEventListener('load',()=>{
  setTimeout(()=>{drawPeriodCanvas();drawDFTCanvas();drawQFTPeaks();drawComplexity();runShortSim();},100);
});
</script>
