  <text x="174" y="90" font-size="9" fill="#888877" text-anchor="middle">⊗ ···</text>

  <!-- REGISTER 2 (b qubits) -->
  <text x="8" y="148" font-size="10" fill="#888877">b</text>
  <text x="8" y="160" font-size="10" fill="#888877">qubits</text>
