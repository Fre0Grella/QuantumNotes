      <input class="answer-input" id="a81b" type="number" style="width:55px;">
      <button class="btn sm" onclick="chk2Shor('a81a',10,'a81b',4,'fb81')">Check</button>
    </div>
    <button class="hint-toggle" onclick="showHintShor('h81')">show hint</button>
    <div class="feedback hint" id="h81">Upper: log₂(1024) = 10 qubits. Lower: ⌈log₂(16)⌉ = 4 qubits (to store 0..15).</div>
    <div class="feedback" id="fb81"></div>
  </div>
</div>

