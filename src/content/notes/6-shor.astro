    </div>
    <div class="feedback" id="fb91"></div>
  </div>
</div>

<!-- Exercise 9.2 -->
<div class="ex-block">
  <div class="ex-header"><span class="ex-tag">Ex 9.2</span><span class="ex-title">Why not just use QFT alone?</span></div>
  <div class="ex-body">
    <p>If the QFT can factor numbers in polynomial time, why can't we just apply QFT directly to a classical list of numbers on a classical computer to break RSA? (hint: what is the bottleneck?)</p>
  </div>
  <div class="answer-area">
    <div class="answer-row">
      <input class="answer-input" id="a92" placeholder="the bottleneck is..." style="width:280px;">
      <button class="btn sm" onclick="chkBottleneck('a92','fb92')">Check</button>
    </div>
    <button class="hint-toggle" onclick="showHintShor('h92')">show hint</button>
    <div class="feedback hint" id="h92">Building the list x₀, x₁, …, x<sub>N−1</sub> requires evaluating f(k) = x<sup>k</sup> mod n for all k. For N ~ n², this requires ~n² evaluations — each taking ~b operations. Total: ~b·2<sup>2b</sup> = exponential in b. The quantum speedup comes from using H<sup>⊗n</sup> to create this superposition with n gates, then using U_f to compute all f(k) simultaneously.</div>
    <div class="feedback" id="fb92"></div>
  </div>
</div>
</section>

<script is:inline>
/* ── HELPERS ── */
function goTo(id){ const el=document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth',block:'start'}); }
function showHintShor(id){ document.getElementById(id).classList.toggle('show'); }
function setFb(id, ok, msg){ const el=document.getElementById(id); el.className='feedback show '+(ok?'ok':'no'); el.textContent=msg; }

function chkNumShor(id,target,fbId){
  const v=parseInt(document.getElementById(id).value);
  const ok=v===target;
  document.getElementById(id).className='answer-input '+(ok?'ok':'no');
  setFb(fbId, ok, ok?`✓ Correct! = ${target}.`:`✗ Got ${v}, expected ${target}.`);
}
function chkMult(id1,id2,product,fbId){
  const a=parseInt(document.getElementById(id1).value), b=parseInt(document.getElementById(id2).value);
  const ok = a*b===product && a>1 && b>1;
  document.getElementById(id1).className='answer-input '+(ok?'ok':'no');
  document.getElementById(id2).className='answer-input '+(ok?'ok':'no');
  setFb(fbId, ok, ok?`✓ Correct! ${a} × ${b} = ${product}.`:`✗ Not quite — find two factors > 1.`);
}
function chk2Shor(id1,t1,id2,t2,fbId){
  const v1=document.getElementById(id1).value.trim(), v2=parseInt(document.getElementById(id2).value);
  const ok1 = typeof t1==='string' ? v1.replace(/\s/g,'')===t1.replace(/\s/g,'') : parseInt(v1)===t1;
  const ok2 = v2===t2;
  document.getElementById(id1).className='answer-input '+(ok1?'ok':'no');
  document.getElementById(id2).className='answer-input '+(ok2?'ok':'no');
  setFb(fbId, ok1&&ok2, (ok1&&ok2)?'✓ Correct!':`✗ Expected ${t1} and ${t2}.`);
}
function chkSuperposQFT(id1,id2,fbId){
  const v1=document.getElementById(id1).value.trim().toUpperCase().replace(/\s/g,'');
  const v2=document.getElementById(id2).value.trim().toLowerCase().replace(/\s/g,'');
  const ok1 = v1==='N' || v1==='2^N' || v1==='2N';
  const ok2 = ['1/√n','1/sqrtn','1/√n'].includes(v2) || v2.includes('1/');
  const ok = ok1 && ok2;
  setFb(fbId, ok, ok?'✓ Correct! N states each with amplitude 1/√N.':`✗ N states, amplitude 1/√N each.`);
}
function chkBottleneck(id,fbId){
  const v=document.getElementById(id).value.toLowerCase();
  const ok = v.includes('eval') || v.includes('list') || v.includes('exponen') || v.includes('f(k)') || v.includes('compute');
  setFb(fbId, ok, ok?'✓ Right! Computing all f(k) = x^k mod n requires N evaluations — that list-building is exponential classically.':`✗ Hint: what prevents a classical computer from evaluating f on N = 2^{2b} inputs?`);
}

function modexp(x, exp, n) {
  let result = 1, base = x % n;
  while (exp > 0) {
    if (exp & 1) result = result * base % n;
    base = base * base % n;
    exp >>= 1;
  }
  return result;
}
function gcd(a, b) { while(b){ let t=b; b=a%b; a=t; } return a; }

/* ── PERIOD CANVAS ── */
let periodX = 2;
function setPeriodX(x) {
  periodX = x;
  ['2','4','7','11'].forEach(k => {
    const b=document.getElementById('px'+k); if(b) b.classList.toggle('active', parseInt(k)===x);
  });
  drawPeriod(x);
}
function drawPeriod(x) {
  const cv=document.getElementById('cvPeriod'); if(!cv) return;
  const ctx=cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const n=15, maxL=20;
  const vals = Array.from({length:maxL},(_,l)=>modexp(x,l,n));
  // Find period
  let P=0;
  for(let r=1;r<n;r++){if(modexp(x,r,n)===1){P=r;break;}}
  const bw=Math.floor((W-60)/(maxL))-2, pad=40, maxV=15;
  const barH = (H-50)/maxV;
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText(`f(ℓ) = ${x}^ℓ mod 15  —  Period P = ${P}`, W/2, 15);
  vals.forEach((v,l)=>{
    const bx=pad+l*(bw+2), h=v*barH;
    ctx.fillStyle = v===1?'#c0392b':'#2c5282';
    ctx.fillRect(bx, H-30-h, bw, h);
    ctx.fillStyle='#888'; ctx.font="8px 'IBM Plex Mono',monospace";
    ctx.fillText(l, bx+bw/2, H-14);
    if(l<16){ ctx.fillStyle='#444'; ctx.font="8px 'IBM Plex Mono',monospace"; ctx.fillText(v, bx+bw/2, H-32-h); }
    // mark period boundaries
    if(l>0 && l%P===0){
      ctx.strokeStyle='#c0392b'; ctx.lineWidth=1; ctx.setLineDash([3,2]);
      ctx.beginPath(); ctx.moveTo(bx,15); ctx.lineTo(bx,H-25); ctx.stroke(); ctx.setLineDash([]);
    }
  });
  document.getElementById('periodInfo').textContent =
    `x=${x}, n=15 → period P=${P}. Red bars: f(ℓ)=1. Dashed lines: period boundaries.`;
}
setPeriodX(2);

/* ── FFT PERIOD CANVAS ── */
let fftX = 2;
function setFFTx(x) {
  fftX = x;
  [2,4,7,11].forEach(k=>{ const b=document.getElementById('fft'+k); if(b) b.classList.toggle('active',k===x); });
  drawFFTperiod(x);
}
function drawFFTperiod(x) {
  const cv=document.getElementById('cvFFTperiod'); if(!cv) return;
  const ctx=cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const n=15, N=64;
  const seq = Array.from({length:N},(_,k)=>modexp(x,k,n));
  // DFT magnitudes
  const mags = Array.from({length:N},(_,q)=>{
    let re=0,im=0;
    seq.forEach((v,k)=>{ re+=v*Math.cos(2*Math.PI*k*q/N); im-=v*Math.sin(2*Math.PI*k*q/N); });
    return Math.sqrt(re*re+im*im)/Math.sqrt(N);
  });
  const maxMag = Math.max(...mags);
  const bw = Math.floor((W-60)/N)-1, pad=30, maxH=H-55;
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText(`FFT of f(ℓ) = ${x}^ℓ mod 15  (N=64)`, W/2, 14);
  mags.forEach((m,q)=>{
    const h=maxMag>0?m/maxMag*maxH*0.85:0;
    const bx=pad+q*(bw+1);
    ctx.fillStyle = h>maxH*0.6 ? '#b7530a' : h>maxH*0.2 ? '#2c5282' : '#dedad0';
    ctx.fillRect(bx,H-30-h,bw,h);
  });
  ctx.strokeStyle='#ccc8ba'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(pad,H-30); ctx.lineTo(W-10,H-30); ctx.stroke();
  ctx.fillStyle='#888'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  [0,16,32,48,63].forEach(q=>ctx.fillText(q, pad+q*(bw+1)+bw/2, H-14));
}
setFFTx(2);

/* ── SHOR STATE CANVAS ── */
function drawShorState() {
  const cv=document.getElementById('cvShorState'); if(!cv) return;
  const ctx=cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  // show positions 0..20 with peaks at 2,6,10,14
  const N=20, pad=30, bw=Math.floor((W-2*pad)/N)-2;
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('Upper register after measuring f(a)=4: amplitudes at ℓ=2,6,10,14,…', W/2, 14);
  for(let k=0;k<N;k++){
    const active=[2,6,10,14,18].includes(k);
    const bx=pad+k*(bw+2), h=active?(H-50):0;
    ctx.fillStyle=active?'#2c5282':'#e8e4d8';
    ctx.fillRect(bx,H-30-h,bw,Math.max(h,2));
    if(k%2===0){ctx.fillStyle='#888';ctx.font="8px 'IBM Plex Mono',monospace";ctx.fillText(k,bx+bw/2,H-14);}
    if(active){ctx.fillStyle='white';ctx.font="bold 8px 'IBM Plex Mono',monospace";ctx.fillText('1/√⌈N/P⌉',bx+bw/2,H-33-h);}
  }
}
drawShorState();

function drawShorQFT() {
  const cv=document.getElementById('cvShorQFT'); if(!cv) return;
  const ctx=cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const peaks=[0,256,512,768], N=1024, display=1023;
  const scale=W-60, pad=30;
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('After QFT₁₀₂₄: peaks at M = 0, 256, 512, 768 (each 25%)', W/2, 14);
  // draw thin baseline
  ctx.strokeStyle='#ccc'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(pad,H-30); ctx.lineTo(W-10,H-30); ctx.stroke();
  peaks.forEach(m=>{
    const x=pad+(m/display)*scale;
    const h=H-55;
    ctx.fillStyle='#b7530a';
    ctx.fillRect(x-5,H-30-h,10,h);
    ctx.fillStyle='#555'; ctx.font="9px 'IBM Plex Mono',monospace";
    ctx.fillText(m, x, H-14);
    ctx.fillText('25%', x, H-33-h);
  });
}
drawShorQFT();

/* ── SHOR INTERACTIVE ── */
function runShor() {
  const n=parseInt(document.getElementById('shorN').value);
  const x=parseInt(document.getElementById('shorX').value);
  const out=document.getElementById('shorOutput');
  let lines=[];
  if(x<=1||x>=n){out.innerHTML='⚠ x must be in (1, n).';return;}
  const g=gcd(x,n);
  lines.push(`① x=${x}, n=${n}  →  gcd(${x},${n}) = ${g}`);
  if(g>1){lines.push(`   Lucky! gcd=${g} is already a factor of ${n}. DONE.`);out.innerHTML=lines.join('<br>');return;}
  // find order
  let r=0;
  for(let k=1;k<n*4;k++){if(modexp(x,k,n)===1){r=k;break;}}
  if(!r){out.innerHTML='Could not find order (x and n may not be coprime).';return;}
  lines.push(`② Order of ${x} mod ${n}: ${x}^${r} mod ${n} = 1  →  r = ${r}`);
  if(r%2!==0){lines.push(`③ r=${r} is odd → restart.`);out.innerHTML=lines.join('<br>');return;}
  const half=modexp(x,r/2,n);
  lines.push(`   x^(r/2) = ${x}^${r/2} mod ${n} = ${half}`);
  const check=(half+1)%n;
  lines.push(`   (x^(r/2)+1) mod n = (${half}+1) mod ${n} = ${check}`);
  if(check===0){lines.push(`③ Check failed (x^(r/2)+1) mod n = 0 → restart.`);out.innerHTML=lines.join('<br>');return;}
  lines.push(`③ r even ✓, check passed ✓`);
  const f1=gcd(half-1,n), f2=gcd(half+1,n);
  lines.push(`④ gcd(x^(r/2)-1, n) = gcd(${half-1}, ${n}) = ${f1}`);
  lines.push(`   gcd(x^(r/2)+1, n) = gcd(${half+1}, ${n}) = ${f2}`);
  if(f1>1&&f1<n) lines.push(`   ✓ Factor found: ${f1}`);
  if(f2>1&&f2<n) lines.push(`   ✓ Factor found: ${f2}`);
  lines.push(`   → ${n} = ${f1} × ${n/f1}`);
  out.innerHTML=lines.join('<br>');
}

/* ── SHOR COMPLEXITY CANVAS ── */
function updateShorComp(){
  const b=parseInt(document.getElementById('slBits').value);
  document.getElementById('bitsVal').textContent=b;
  drawShorComp(b);
  const shor=Math.pow(b,3), classical=Math.exp(Math.pow(b,1/3)*Math.pow(Math.log(b),2/3));
  document.getElementById('shorCompInfo').textContent=
    `b=${b}: Shor O(b³) ≈ ${shor.toFixed(0)} · Classical O(e^(b^1/3·(ln b)^2/3)) ≈ 10^${(Math.log10(classical)).toFixed(1)}`;
}
function drawShorComp(bCur){
  const cv=document.getElementById('cvShorComp'); if(!cv) return;
  const ctx=cv.getContext('2d'), W=cv.width, H=cv.height;
  ctx.clearRect(0,0,W,H); ctx.fillStyle='#fafaf8'; ctx.fillRect(0,0,W,H);
  const PL=60, PR=20, PT=20, PB=50, pW=W-PL-PR, pH=H-PT-PB;
  const bMax=100;
  // compute log values
  function logShor(b){ return 3*Math.log10(b); }
  function logClass(b){ return Math.pow(b,1/3)*Math.pow(Math.log(b),2/3)*Math.log10(Math.E); }
  const maxLog = logClass(bMax);
  const toY = l => PT+pH - Math.min(l/maxLog,1)*pH;
  // grid
  [5,10,15,20].forEach(e=>{
    const y=toY(e); if(y<PT) return;
    ctx.strokeStyle='#eee'; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(PL,y); ctx.lineTo(W-PR,y); ctx.stroke();
    ctx.fillStyle='#aaa'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='right';
    ctx.fillText('10^'+e, PL-5, y+3);
  });
  // draw curves
  function curve(fn, col, lw){
    ctx.strokeStyle=col; ctx.lineWidth=lw;
    ctx.beginPath();
    for(let b=5;b<=bMax;b++){
      const x=PL+(b-5)/(bMax-5)*pW, y=toY(fn(b));
      b===5?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.stroke();
  }
  curve(logClass,'#c0392b',2);
  curve(logShor,'#2c5282',2);
  // current b marker
  const bx=PL+(bCur-5)/(bMax-5)*pW;
  ctx.strokeStyle='#888'; ctx.setLineDash([3,3]); ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(bx,PT); ctx.lineTo(bx,PT+pH); ctx.stroke(); ctx.setLineDash([]);
  ctx.fillStyle='#888'; ctx.font="10px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
  ctx.fillText('b='+bCur, bx, PT+pH+14);
  // labels
  ctx.textAlign='left';
  ctx.fillStyle='#c0392b'; ctx.font="10px 'IBM Plex Mono',monospace";
  ctx.fillText('Classical: O(e^(b^(1/3)·(ln b)^(2/3)))', PL+5, PT+14);
  ctx.fillStyle='#2c5282';
  ctx.fillText("Shor: O(b³)", PL+5, PT+28);
  // x axis
  [10,20,40,60,80,100].forEach(b=>{
    const x=PL+(b-5)/(bMax-5)*pW;
    ctx.fillStyle='#888'; ctx.font="9px 'IBM Plex Mono',monospace"; ctx.textAlign='center';
    ctx.fillText(b, x, PT+pH+28);
  });
  ctx.fillStyle='#888'; ctx.textAlign='center';
  ctx.fillText('b (bits)', PL+pW/2, PT+pH+44);
}
updateShorComp();
</script>
